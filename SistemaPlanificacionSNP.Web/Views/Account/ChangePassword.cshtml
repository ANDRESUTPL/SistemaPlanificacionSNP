@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-key"></i> Cambiar Contraseña</h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @ViewBag.Success
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> 
                            <ul class="mb-0">
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" asp-action="ChangePassword">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="PasswordActual" class="form-label">Contraseña Actual</label>
                            <input asp-for="PasswordActual" type="password" class="form-control" required>
                            <span asp-validation-for="PasswordActual" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PasswordNueva" class="form-label">Contraseña Nueva</label>
                            <input asp-for="PasswordNueva" type="password" class="form-control" placeholder="Mínimo 8 caracteres" required>
                            <span asp-validation-for="PasswordNueva" class="text-danger"></span>
                            <small class="form-text text-muted">Debe contener al menos 8 caracteres</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PasswordConfirmar" class="form-label">Confirmar Contraseña</label>
                            <input asp-for="PasswordConfirmar" type="password" class="form-control" required>
                            <span asp-validation-for="PasswordConfirmar" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Guardar Cambios
                            </button>
                            <a href="/" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
