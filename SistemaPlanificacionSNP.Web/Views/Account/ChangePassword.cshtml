@model SistemaPlanificacionSNP.Web.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<!-- Contenedor fluido para aprovechar todo el ancho -->
<div class="container-fluid p-0">

    <!-- Encabezado de la página -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-lock me-2 text-primary"></i>Gestión de Seguridad</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Actualización de credenciales de acceso al sistema.</p>
        </div>
        <div class="mt-3 mt-md-0">
            <a href="/account/profile" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-arrow-left me-2"></i> Volver al Perfil
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Columna Izquierda (Formulario de Cambio de Contraseña) -->
        <div class="col-12 col-xl-7 col-xxl-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex align-items-center">
                    <div class="rounded-3 p-2 d-flex align-items-center justify-content-center me-3" style="background-color: #eff6ff; color: #3b82f6;">
                        <i class="fas fa-key fs-5"></i>
                    </div>
                    <h5 class="mb-0 fw-bold text-dark">Actualizar Contraseña</h5>
                </div>

                <div class="card-body p-4 p-xl-5">

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(x => x.Errors.Count > 0))
                    {
                        <div class="alert alert-danger border-0 border-start border-4 border-danger shadow-sm rounded-3 d-flex mb-4" role="alert">
                            <i class="fas fa-exclamation-circle fs-5 me-3 text-danger mt-1"></i>
                            <div>
                                <h6 class="fw-bold mb-1 text-danger">Error de validación</h6>
                                <ul class="mb-0 text-danger text-opacity-75 ps-3" style="font-size: 0.9rem;">
                                    @foreach (var modelState in ViewData.ModelState.Values)
                                    {
                                        @foreach (var error in modelState.Errors)
                                        {
                                            <li>@error.ErrorMessage</li>
                                        }
                                    }
                                </ul>
                            </div>
                        </div>
                    }

                    <form method="post" asp-action="ChangePassword" id="changePasswordForm">
                        @Html.AntiForgeryToken()

                        <div class="row g-4">
                            <!-- Contraseña Actual -->
                            <div class="col-12 mb-2">
                                <label asp-for="PasswordActual" class="form-label text-muted fw-bold text-xs text-uppercase tracking-wider">Contraseña Actual</label>
                                <div class="input-group input-group-lg shadow-sm">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="fas fa-unlock-alt"></i></span>
                                    <input asp-for="PasswordActual" type="password" class="form-control border-start-0 ps-0 bg-light" placeholder="Ingresa tu contraseña vigente" required>
                                    <span class="input-group-text bg-light border-start-0 text-muted" onclick="togglePassword('PasswordActual', this)" style="cursor: pointer;" title="Mostrar/Ocultar contraseña">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                                <span asp-validation-for="PasswordActual" class="text-danger text-xs mt-1 d-block"></span>
                            </div>

                            <div class="col-12"><hr class="border-light-subtle my-2"></div>

                            <!-- Contraseña Nueva -->
                            <div class="col-md-6">
                                <label asp-for="PasswordNueva" class="form-label text-muted fw-bold text-xs text-uppercase tracking-wider">Nueva Contraseña</label>
                                <div class="input-group input-group-lg shadow-sm">
                                    <span class="input-group-text bg-white border-end-0 text-primary"><i class="fas fa-lock"></i></span>
                                    <input asp-for="PasswordNueva" type="password" id="nuevaPassword" class="form-control border-start-0 ps-0" placeholder="Nueva contraseña segura" required minlength="8">
                                    <span class="input-group-text bg-white border-start-0 text-muted" onclick="togglePassword('nuevaPassword', this)" style="cursor: pointer;" title="Mostrar/Ocultar contraseña">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                                <span asp-validation-for="PasswordNueva" class="text-danger text-xs mt-1 d-block"></span>

                                <!-- Medidor de fuerza de contraseña -->
                                <div class="mt-2" id="passwordStrengthContainer" style="display: none;">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="text-xs fw-bold text-muted">Nivel de seguridad</span>
                                        <span class="text-xs fw-bold" id="strengthText">Débil</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar" id="strengthBar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                            </div>

                            <!-- Confirmar Contraseña -->
                            <div class="col-md-6">
                                <label asp-for="PasswordConfirmar" class="form-label text-muted fw-bold text-xs text-uppercase tracking-wider">Confirmar Contraseña</label>
                                <div class="input-group input-group-lg shadow-sm">
                                    <span class="input-group-text bg-white border-end-0 text-primary"><i class="fas fa-check-double"></i></span>
                                    <input asp-for="PasswordConfirmar" type="password" id="confirmPassword" class="form-control border-start-0 ps-0" placeholder="Repite la nueva contraseña" required minlength="8">
                                    <span class="input-group-text bg-white border-start-0 text-muted" onclick="togglePassword('confirmPassword', this)" style="cursor: pointer;" title="Mostrar/Ocultar contraseña">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                                <span asp-validation-for="PasswordConfirmar" class="text-danger text-xs mt-1 d-block"></span>
                                <div id="matchMessage" class="text-xs mt-2 fw-medium d-none"></div>
                            </div>

                            <!-- Botón de Envío -->
                            <div class="col-12 mt-5 text-end">
                                <button type="button" class="btn btn-outline-danger me-2 px-4 rounded-pill" onclick="document.getElementById('changePasswordForm').reset(); resetMeters();">
                                    Cancelar
                                </button>
                                <button type="submit" class="btn btn-outline-primary me-2 px-4 rounded-pill" id="submitBtn">
                                    <i class="fas fa-save me-2"></i> Guardar Cambios
                                    <div class="spinner-border spinner-border-sm text-white ms-2 d-none" id="btnSpinner" role="status"></div>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Columna Derecha (Panel de Recomendaciones de Seguridad) -->
        <div class="col-12 col-xl-5 col-xxl-4">
            <div class="card border-0 shadow-sm bg-light h-100">
                <div class="card-body p-4 p-xl-5">

                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px; color: #10b981;">
                            <i class="fas fa-shield-alt fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Política de Seguridad</h5>
                        <p class="text-muted text-sm">Criterios obligatorios para proteger tu acceso al sistema SNP.</p>
                    </div>

                    <div class="bg-white p-4 rounded-3 shadow-sm border border-light-subtle">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-3 d-flex align-items-start">
                                <i class="fas fa-check-circle text-success mt-1 me-3"></i>
                                <div>
                                    <span class="fw-bold text-dark d-block text-sm">Longitud Mínima</span>
                                    <span class="text-muted text-xs">Debe contener al menos 8 caracteres de longitud.</span>
                                </div>
                            </li>
                            <li class="mb-3 d-flex align-items-start">
                                <i class="fas fa-check-circle text-success mt-1 me-3"></i>
                                <div>
                                    <span class="fw-bold text-dark d-block text-sm">Complejidad</span>
                                    <span class="text-muted text-xs">Incluir letras mayúsculas, minúsculas, números y símbolos especiales (ej. @@, #, $).</span>
                                </div>
                            </li>
                            <li class="mb-3 d-flex align-items-start">
                                <i class="fas fa-check-circle text-success mt-1 me-3"></i>
                                <div>
                                    <span class="fw-bold text-dark d-block text-sm">No reciclaje</span>
                                    <span class="text-muted text-xs">No utilices contraseñas que hayas usado anteriormente en este sistema.</span>
                                </div>
                            </li>
                            <li class="d-flex align-items-start">
                                <i class="fas fa-info-circle text-primary mt-1 me-3"></i>
                                <div>
                                    <span class="fw-bold text-dark d-block text-sm">Cierre de sesión</span>
                                    <span class="text-muted text-xs">Tras cambiar la contraseña, tus otras sesiones activas podrían cerrarse por seguridad.</span>
                                </div>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Partial de validaciones de ASP.NET Core -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {

            const form = document.getElementById('changePasswordForm');
            const submitBtn = document.getElementById('submitBtn');
            const btnSpinner = document.getElementById('btnSpinner');

            const newPwd = document.getElementById('nuevaPassword');
            const confirmPwd = document.getElementById('confirmPassword');
            const matchMsg = document.getElementById('matchMessage');

            const strengthContainer = document.getElementById('passwordStrengthContainer');
            const strengthBar = document.getElementById('strengthBar');
            const strengthText = document.getElementById('strengthText');

            // 1. Mostrar Spinner al enviar el formulario
            form.addEventListener('submit', function(e) {
                // Solo si el formulario es válido según jQuery Validate (si está cargado)
                if ($(this).valid()) {
                    submitBtn.classList.add('disabled');
                    submitBtn.style.opacity = '0.8';
                    btnSpinner.classList.remove('d-none');
                }
            });

            // 2. Medidor de Fuerza de Contraseña (Lado Cliente)
            newPwd.addEventListener('input', function() {
                const val = this.value;
                if (val.length > 0) {
                    strengthContainer.style.display = 'block';
                } else {
                    strengthContainer.style.display = 'none';
                    return;
                }

                let score = 0;
                if (val.length > 7) score += 25;
                if (val.match(/[a-z]/)) score += 25;
                if (val.match(/[A-Z]/)) score += 25;
                if (val.match(/\d/)) score += 10;
                if (val.match(/[^a-zA-Z\d]/)) score += 15;

                strengthBar.style.width = score + '%';

                strengthBar.className = 'progress-bar'; // reset
                strengthText.className = 'text-xs fw-bold'; // reset

                if (score < 50) {
                    strengthBar.classList.add('bg-danger');
                    strengthText.textContent = 'Débil';
                    strengthText.classList.add('text-danger');
                } else if (score >= 50 && score < 80) {
                    strengthBar.classList.add('bg-warning');
                    strengthText.textContent = 'Aceptable';
                    strengthText.classList.add('text-warning');
                } else {
                    strengthBar.classList.add('bg-success');
                    strengthText.textContent = 'Fuerte';
                    strengthText.classList.add('text-success');
                }

                checkPasswordsMatch();
            });

            // 3. Verificación de contraseñas coincidentes en tiempo real
            confirmPwd.addEventListener('input', checkPasswordsMatch);

            function checkPasswordsMatch() {
                const p1 = newPwd.value;
                const p2 = confirmPwd.value;

                if (p2.length === 0) {
                    matchMsg.classList.add('d-none');
                    return;
                }

                matchMsg.classList.remove('d-none');

                if (p1 === p2) {
                    matchMsg.textContent = '✔ Las contraseñas coinciden';
                    matchMsg.className = 'text-xs mt-2 fw-bold text-success';
                } else {
                    matchMsg.textContent = '✘ Las contraseñas no coinciden';
                    matchMsg.className = 'text-xs mt-2 fw-bold text-danger';
                }
            }
        });

        // Función para limpiar contadores al cancelar
        function resetMeters() {
            document.getElementById('passwordStrengthContainer').style.display = 'none';
            document.getElementById('matchMessage').classList.add('d-none');

            // Restaurar los tipos de input a password si estaban en texto al limpiar el form
            const ids = ['currentPassword', 'nuevaPassword', 'confirmPassword'];
            ids.forEach(id => {
                const input = document.getElementById(id);
                if (input && input.type === 'text') {
                    togglePassword(id, input.nextElementSibling);
                }
            });
        }
        // Función para alternar la visibilidad de la contraseña
        function togglePassword(inputId, element) {
            const input = document.getElementById(inputId);
            const icon = element.querySelector('i');

            if (input.type === 'password') {
                // Mostrar contraseña
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash', 'text-primary');
            } else {
                // Ocultar contraseña
                input.type = 'password';
                icon.classList.remove('fa-eye-slash', 'text-primary');
                icon.classList.add('fa-eye');
            }
        }
    </script>
}