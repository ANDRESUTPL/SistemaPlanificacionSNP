@model SistemaPlanificacionSNP.Web.Models.UserProfileViewModel

@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="card-body px-4 px-md-5 pb-5 position-relative" style="margin-top: -50px;">
    <!-- Avatar -->
    <div class="d-flex align-items-end mb-4">
        <div class="profile-avatar-large shadow-sm border border-white border-4">
            <i class="fas fa-user"></i>
        </div>
        <div class="ms-3 pb-2">
            <h4 class="mb-0 fw-bold">@Model.Nombre @Model.Apellido</h4>
            <span class="badge @(Model.Activo ? "bg-success" : "bg-danger") mt-1">
                @(Model.Activo ? "Usuario Activo" : "Usuario Inactivo")
            </span>
        </div>
    </div>

    <hr class="mb-4">

    <h6 class="fw-bold mb-3 text-dark"><i class="fas fa-address-card me-2 text-primary"></i> Información Personal</h6>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="data-label">Nombre de Usuario</div>
            <div class="data-value">@Model.NombreUsuario</div>
        </div>

        <div class="col-md-6">
            <div class="data-label">Correo Electrónico</div>
            <div class="data-value">@Model.Email</div>
        </div>

        <div class="col-md-6">
            <div class="data-label">Nombres</div>
            <div class="data-value">@Model.Nombre</div>
        </div>

        <div class="col-md-6">
            <div class="data-label">Apellidos</div>
            <div class="data-value">@Model.Apellido</div>
        </div>

        <div class="col-md-6">
            <div class="data-label">ID de Sistema</div>
            <div class="data-value">#@Model.UsuarioId</div>
        </div>

        <div class="col-md-6">
            <div class="data-label">Fecha de Registro</div>
            <div class="data-value">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
        <a href="javascript:history.back()" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i> Volver
        </a>
        <a href="/account/change-password" class="btn btn-primary">
            <i class="fas fa-key me-2"></i> Cambiar Contraseña
        </a>
    </div>
</div>
</div>
</div>
