@model SistemaPlanificacionSNP.Web.Models.UsuarioEditViewModel

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-user-edit me-2 text-primary"></i>Editar Usuario</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Actualiza los datos del usuario y su estado de activacion.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/seguridad/usuarios/@Model.UsuarioId" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-eye me-2"></i>Ver detalle
            </a>
            <a href="/seguridad/usuarios" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger border-0 border-start border-4 shadow-sm rounded-3 d-flex" role="alert">
            <i class="fas fa-exclamation-circle mt-1 me-3"></i>
            <div>
                <h6 class="fw-bold mb-1">No fue posible guardar cambios</h6>
                <div asp-validation-summary="All" class="mb-0"></div>
            </div>
        </div>
    }

    <form method="post" action="/seguridad/usuarios/@Model.UsuarioId/editar" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UsuarioId" />
        <input type="hidden" asp-for="NombreUsuario" />
        <input type="hidden" asp-for="FechaCreacion" />

        <div class="row g-4">
            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white pt-4 pb-3 border-bottom px-4">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-id-card me-2 text-primary"></i>Datos del Usuario</h5>
                    </div>

                    <div class="card-body p-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="NombreUsuario" class="form-label fw-medium"></label>
                                <input asp-for="NombreUsuario" class="form-control" readonly />
                            </div>

                            <div class="col-12">
                                <label asp-for="Email" class="form-label fw-medium"></label>
                                <input asp-for="Email" class="form-control" maxlength="100" autocomplete="off" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="col-12 col-lg-6">
                                <label asp-for="Nombre" class="form-label fw-medium"></label>
                                <input asp-for="Nombre" class="form-control" maxlength="100" autocomplete="off" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>

                            <div class="col-12 col-lg-6">
                                <label asp-for="Apellido" class="form-label fw-medium"></label>
                                <input asp-for="Apellido" class="form-control" maxlength="100" autocomplete="off" />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <div class="form-check form-switch mt-2">
                                    <input asp-for="Activo" class="form-check-input" role="switch" />
                                    <label asp-for="Activo" class="form-check-label"></label>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="small text-muted">Creado: @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/seguridad/usuarios" class="btn btn-outline-secondary px-4">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fas fa-save me-2"></i>Guardar cambios
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-user-shield me-2 text-primary"></i>Roles actuales</h5>
                        <span class="badge rounded-pill text-bg-light border">@Model.Roles.Count rol(es)</span>
                    </div>
                    <div class="card-body p-4">
                        @if (Model.Roles.Count == 0)
                        {
                            <p class="text-muted mb-0">Este usuario no tiene roles asignados.</p>
                        }
                        else
                        {
                            @foreach (var rol in Model.Roles)
                            {
                                <span class="badge rounded-pill bg-info bg-opacity-10 text-info border border-info-subtle me-1 mb-1">@rol.Nombre</span>
                            }
                        }
                        <div class="mt-3">
                            <a href="/seguridad/usuarios?rolesUsuarioId=@Model.UsuarioId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                <i class="fas fa-shield-alt me-1"></i>Gestionar roles
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-table me-2 text-primary"></i>Permisos efectivos</h5>
                        <span class="badge rounded-pill text-bg-light border">@Model.PermisosPorPantalla.Count pantalla(s)</span>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.PermisosPorPantalla.Count == 0)
                        {
                            <div class="p-4 text-muted">No hay permisos efectivos para mostrar.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-light bg-opacity-50">
                                        <tr>
                                            <th class="ps-4 border-0 text-xs text-muted fw-bold">PANTALLA</th>
                                            <th class="border-0 text-xs text-muted fw-bold text-center">LECTURA</th>
                                            <th class="border-0 text-xs text-muted fw-bold text-center">CREACION</th>
                                            <th class="border-0 text-xs text-muted fw-bold text-center">EDICION</th>
                                            <th class="pe-4 border-0 text-xs text-muted fw-bold text-center">ELIMINACION</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var permiso in Model.PermisosPorPantalla)
                                        {
                                            <tr>
                                                <td class="ps-4 fw-medium">@permiso.PantallaNombre</td>
                                                <td class="text-center"><i class="fas @(permiso.Lectura ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i></td>
                                                <td class="text-center"><i class="fas @(permiso.Creacion ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i></td>
                                                <td class="text-center"><i class="fas @(permiso.Edicion ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i></td>
                                                <td class="pe-4 text-center"><i class="fas @(permiso.Eliminacion ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
   
}
