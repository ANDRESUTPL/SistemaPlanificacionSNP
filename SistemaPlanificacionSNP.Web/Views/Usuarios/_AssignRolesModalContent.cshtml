@model SistemaPlanificacionSNP.Web.Models.RolesUsuariosEditViewModel
@using System.Text.Json

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger border-0 border-start border-4 rounded-3 d-flex" role="alert">
        <i class="fas fa-exclamation-circle mt-1 me-3"></i>
        <div>
            <h6 class="fw-bold mb-1">No fue posible guardar cambios</h6>
            <div asp-validation-summary="All" class="mb-0"></div>
        </div>
    </div>
}

<form method="post" action="/seguridad/usuarios/@Model.UsuarioId/roles" id="assign-roles-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UsuarioId" />

    <div class="row g-4">
        <div class="col-12 col-xl-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-id-card me-2 text-primary"></i>Resumen del usuario</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <div class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Usuario</div>
                        <div class="fw-semibold text-dark">@Model.NombreUsuario</div>
                    </div>
                    <div class="mb-3">
                        <div class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Nombre</div>
                        <div class="fw-semibold text-dark">@Model.NombreCompleto</div>
                    </div>
                    <div class="mb-3">
                        <div class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Correo</div>
                        <div class="fw-medium text-dark">@Model.Email</div>
                    </div>
                    <div>
                        <div class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.7rem; letter-spacing: 0.5px;">Estado</div>
                        @if (Model.Activo)
                        {
                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle">Activo</span>
                        }
                        else
                        {
                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger-subtle">Inactivo</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-shield-alt me-2 text-primary"></i>Roles disponibles</h6>
                    <span class="badge rounded-pill text-bg-light border">@Model.RolesDisponibles.Count rol(es)</span>
                </div>
                <div class="card-body p-4">
                    @if (Model.RolesDisponibles.Count == 0)
                    {
                        <div class="alert alert-warning mb-0 border-0 border-start border-4 rounded-3 d-flex" role="alert">
                            <i class="fas fa-info-circle mt-1 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Sin catalogo de roles</h6>
                                <p class="mb-0">La API no devolvio roles para seleccion. Intenta nuevamente en unos minutos.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var rol in Model.RolesDisponibles)
                            {
                                var isChecked = Model.SelectedRolIds.Contains(rol.RolId);
                                <div class="col-12 col-md-6">
                                    <label class="w-100 p-3 border rounded-3 d-flex align-items-center justify-content-between" style="cursor: pointer;">
                                        <span class="fw-medium text-dark">@rol.Nombre</span>
                                        <input type="checkbox"
                                               class="form-check-input role-toggle"
                                               name="SelectedRolIds"
                                               value="@rol.RolId"
                                               data-role-id="@rol.RolId"
                                               @(isChecked ? "checked" : null) />
                                    </label>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-table me-2 text-primary"></i>Permisos efectivos por pantalla</h6>
                    <span id="roles-permisos-count-badge" class="badge rounded-pill text-bg-light border">@Model.PermisosPorPantalla.Count pantalla(s)</span>
                </div>
                <div class="card-body p-0">
                    <div id="roles-permisos-empty-state" class="p-4 @(Model.PermisosPorPantalla.Count == 0 ? string.Empty : "d-none")">
                        <div class="alert alert-warning mb-0 border-0 border-start border-4 rounded-3 d-flex" role="alert">
                            <i class="fas fa-info-circle mt-1 me-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Sin matriz de permisos</h6>
                                <p class="mb-0">No hay permisos asociados a los roles seleccionados.</p>
                            </div>
                        </div>
                    </div>

                    <div id="roles-permisos-table-wrapper" class="table-responsive @(Model.PermisosPorPantalla.Count == 0 ? "d-none" : string.Empty)">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 border-0 text-xs text-muted fw-bold">PANTALLA</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">LECTURA</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">CREACION</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">EDICION</th>
                                    <th class="pe-4 border-0 text-xs text-muted fw-bold text-center">ELIMINACION</th>
                                </tr>
                            </thead>
                            <tbody id="roles-permisos-matrix-body">
                                @foreach (var permiso in Model.PermisosPorPantalla)
                                {
                                    <tr>
                                        <td class="ps-4 fw-medium">@permiso.PantallaNombre</td>
                                        <td class="text-center"><i class="fas @(permiso.Lectura ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i></td>
                                        <td class="text-center"><i class="fas @(permiso.Creacion ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i></td>
                                        <td class="text-center"><i class="fas @(permiso.Edicion ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i></td>
                                        <td class="pe-4 text-center"><i class="fas @(permiso.Eliminacion ? "fa-check-circle text-success" : "fa-times-circle text-danger")"></i></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save me-2"></i>Guardar asignacion
        </button>
    </div>
</form>

<script type="application/json" id="roles-permisos-json">@Html.Raw(JsonSerializer.Serialize(Model.RolesPermisosCliente))</script>
