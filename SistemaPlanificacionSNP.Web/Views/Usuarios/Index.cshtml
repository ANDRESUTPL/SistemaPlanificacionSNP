@model SistemaPlanificacionSNP.Web.Models.UsuariosIndexViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Administracion de Usuarios";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-users me-2 text-primary"></i>Administracion de Usuarios</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Gestion de usuarios del sistema, estado y datos de perfil.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/seguridad/usuarios/crear" class="btn btn-primary border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-user-plus me-2"></i>Nuevo usuario
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <form method="get" action="/seguridad/usuarios" class="row g-3 align-items-end">
                <div class="col-12 col-lg-5">
                    <label class="form-label fw-medium">Buscar</label>
                    <input type="text" name="buscar" value="@Model.Buscar" class="form-control" placeholder="Usuario, nombre, apellido o correo" />
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label fw-medium">Estado</label>
                    <select class="form-select" name="activo">
                        <option value="">Todos</option>
                        <option value="true" selected="@(Model.Activo == true)">Activos</option>
                        <option value="false" selected="@(Model.Activo == false)">Inactivos</option>
                    </select>
                </div>

                <div class="col-6 col-md-3 col-lg-2">
                    <label class="form-label fw-medium">Tamano</label>
                    <select class="form-select" name="pageSize">
                        <option value="10" selected="@(Model.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    </select>
                </div>

                <div class="col-6 col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-filter me-1"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent pt-4 pb-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-user-cog me-2 text-primary"></i>Listado de Usuarios</h6>
            <span class="badge rounded-pill text-bg-light border">@Model.TotalCount registro(s)</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr>
                            <th class="ps-4 border-0 text-xs text-muted fw-bold">USUARIO</th>
                            <th class="border-0 text-xs text-muted fw-bold">NOMBRE</th>
                            <th class="border-0 text-xs text-muted fw-bold">ESTADO</th>
                            <th class="border-0 text-xs text-muted fw-bold">ROLES ASIGNADOS</th>
                            <th class="pe-4 border-0 text-xs text-muted fw-bold text-end">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Usuarios.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No se encontraron usuarios para los filtros aplicados.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var usuario in Model.Usuarios)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-semibold text-dark">@usuario.NombreUsuario</div>
                                        <div class="text-muted" style="font-size: 0.85rem;">@usuario.Email</div>
                                    </td>
                                    <td>@usuario.NombreCompleto</td>
                                    <td>
                                        @if (usuario.Activo)
                                        {
                                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger-subtle">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        @if (usuario.Roles.Count == 0)
                                        {
                                            <span class="text-muted" style="font-size: 0.9rem;">Sin roles</span>
                                        }
                                        else
                                        {
                                            @foreach (var rol in usuario.Roles)
                                            {
                                                <span class="badge rounded-pill bg-info bg-opacity-10 text-info border border-info-subtle me-1 mb-1">@rol.Nombre</span>
                                            }
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-inline-flex gap-2">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-info rounded-pill px-3 js-open-roles-modal"
                                                    data-usuario-id="@usuario.UsuarioId"
                                                    data-usuario="@usuario.NombreUsuario">
                                                <i class="fas fa-shield-alt me-1"></i>Gestionar roles
                                            </button>
                                            <a href="/seguridad/usuarios/@usuario.UsuarioId" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                                <i class="fas fa-eye me-1"></i>Ver
                                            </a>
                                            <a href="/seguridad/usuarios/@usuario.UsuarioId/editar" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                <i class="fas fa-pen me-1"></i>Editar
                                            </a>
                                            <form method="post" action="/seguridad/usuarios/@usuario.UsuarioId/eliminar" class="d-inline js-delete-user-form" data-usuario="@usuario.NombreUsuario" data-activo="@(usuario.Activo ? "true" : "false")">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                    <i class="fas fa-trash me-1"></i>Eliminar
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Paginacion de usuarios">
            <ul class="pagination justify-content-end">
                <li class="page-item @(Model.Page == 1 ? "disabled" : string.Empty)">
                    <a class="page-link"
                       href="/seguridad/usuarios?buscar=@Model.Buscar&activo=@Model.Activo&page=@(Model.Page - 1)&pageSize=@Model.PageSize">Anterior</a>
                </li>

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : string.Empty)">
                        <a class="page-link" href="/seguridad/usuarios?buscar=@Model.Buscar&activo=@Model.Activo&page=@i&pageSize=@Model.PageSize">@i</a>
                    </li>
                }

                <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : string.Empty)">
                    <a class="page-link"
                       href="/seguridad/usuarios?buscar=@Model.Buscar&activo=@Model.Activo&page=@(Model.Page + 1)&pageSize=@Model.PageSize">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
</div>

<div class="modal fade" id="rolesModal" tabindex="-1" aria-labelledby="rolesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="rolesModalLabel">Gestionar roles</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body" id="roles-modal-body">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));
            const rolesModalElement = document.getElementById('rolesModal');
            const rolesModalBody = document.getElementById('roles-modal-body');
            const modalTitle = document.getElementById('rolesModalLabel');
            const rolesModal = rolesModalElement ? new bootstrap.Modal(rolesModalElement) : null;
            const openRolesForUserId = new URLSearchParams(window.location.search).get('rolesUsuarioId');

            if (swalSuccess) {
                Swal.fire({
                    title: 'Operacion exitosa',
                    text: swalSuccess,
                    icon: 'success',
                    confirmButtonText: 'Continuar'
                });
            } else if (swalWarning) {
                Swal.fire({
                    title: 'Atencion',
                    text: swalWarning,
                    icon: 'warning',
                    confirmButtonText: 'Entendido'
                });
            }

            const deleteForms = document.querySelectorAll('.js-delete-user-form');
            if (!deleteForms.length) {
                // No return: role modal handlers still need initialization.
            }

            deleteForms.forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    event.preventDefault();

                    const usuario = form.dataset.usuario || 'este usuario';
                    const activo = form.dataset.activo === 'true';
                    const estado = activo ? 'activo' : 'inactivo';

                    Swal.fire({
                        title: 'Confirmar eliminacion',
                        html: `Se eliminara el usuario <strong>${usuario}</strong> (${estado}).<br>Esta accion no se puede deshacer.`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Si, eliminar',
                        cancelButtonText: 'Cancelar',
                        confirmButtonColor: '#dc3545',
                        reverseButtons: true,
                        focusCancel: true
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                });
            });

            function parseRolesPermisos() {
                const jsonNode = document.getElementById('roles-permisos-json');
                if (!jsonNode) {
                    return [];
                }

                try {
                    return JSON.parse(jsonNode.textContent || '[]');
                } catch {
                    return [];
                }
            }

            function iconCell(hasAccess, isLast) {
                const lastClass = isLast ? ' pe-4' : '';
                const icon = hasAccess ? 'fa-check-circle text-success' : 'fa-times-circle text-danger';
                return `<td class="text-center${lastClass}"><i class="fas ${icon}"></i></td>`;
            }

            function buildMatrix(selectedRoleIds, rolesPermisos) {
                const selectedRoles = rolesPermisos.filter(r => selectedRoleIds.includes(r.rolId || r.RolId));
                const pantallaMap = new Map();

                selectedRoles.forEach(role => {
                    const permisos = role.permisos || role.Permisos || [];

                    permisos.forEach(permiso => {
                        const pantallaId = permiso.pantallaId || permiso.PantallaId;
                        const nombrePantalla = permiso.nombrePantalla || permiso.NombrePantalla || `Pantalla ${pantallaId}`;

                        if (!pantallaMap.has(pantallaId)) {
                            pantallaMap.set(pantallaId, {
                                pantallaId,
                                nombrePantalla,
                                lectura: false,
                                creacion: false,
                                edicion: false,
                                eliminacion: false
                            });
                        }

                        const row = pantallaMap.get(pantallaId);
                        row.lectura = row.lectura || Boolean(permiso.lectura ?? permiso.Lectura);
                        row.creacion = row.creacion || Boolean(permiso.creacion ?? permiso.Creacion);
                        row.edicion = row.edicion || Boolean(permiso.edicion ?? permiso.Edicion);
                        row.eliminacion = row.eliminacion || Boolean(permiso.eliminacion ?? permiso.Eliminacion);
                    });
                });

                return Array.from(pantallaMap.values()).sort((a, b) => a.pantallaId - b.pantallaId);
            }

            function renderMatrix(matrix) {
                const matrixBody = document.getElementById('roles-permisos-matrix-body');
                const emptyState = document.getElementById('roles-permisos-empty-state');
                const tableWrapper = document.getElementById('roles-permisos-table-wrapper');
                const countBadge = document.getElementById('roles-permisos-count-badge');

                if (!matrixBody || !emptyState || !tableWrapper || !countBadge) {
                    return;
                }

                countBadge.textContent = `${matrix.length} pantalla(s)`;
                if (matrix.length === 0) {
                    matrixBody.innerHTML = '';
                    tableWrapper.classList.add('d-none');
                    emptyState.classList.remove('d-none');
                    return;
                }

                matrixBody.innerHTML = matrix.map(item => `
                    <tr>
                        <td class="ps-4 fw-medium">${item.nombrePantalla}</td>
                        ${iconCell(item.lectura, false)}
                        ${iconCell(item.creacion, false)}
                        ${iconCell(item.edicion, false)}
                        ${iconCell(item.eliminacion, true)}
                    </tr>
                `).join('');

                emptyState.classList.add('d-none');
                tableWrapper.classList.remove('d-none');
            }

            function initializeAssignRolesModal() {
                const form = document.getElementById('assign-roles-form');
                if (!form) {
                    return;
                }

                const roleCheckboxes = Array.from(form.querySelectorAll('.role-toggle'));
                const rolesPermisos = parseRolesPermisos();
                const saveButton = form.querySelector('button[type="submit"]');

                const refreshMatrix = () => {
                    const selectedRoleIds = roleCheckboxes
                        .filter(cb => cb.checked)
                        .map(cb => Number(cb.dataset.roleId));
                    const matrix = buildMatrix(selectedRoleIds, rolesPermisos);
                    renderMatrix(matrix);
                };

                roleCheckboxes.forEach(cb => cb.addEventListener('change', refreshMatrix));
                refreshMatrix();

                form.addEventListener('submit', async function (event) {
                    event.preventDefault();

                    const selectedCount = roleCheckboxes.filter(cb => cb.checked).length;
                    if (selectedCount === 0) {
                        const confirmed = window.confirm('Esta accion dejara al usuario sin roles asignados. Deseas continuar?');
                        if (!confirmed) {
                            return;
                        }
                    }

                    if (saveButton) {
                        saveButton.disabled = true;
                        saveButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Guardando...';
                    }

                    const formData = new FormData(form);

                    try {
                        const response = await fetch(form.action, {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        const contentType = response.headers.get('content-type') || '';
                        if (contentType.includes('application/json')) {
                            const payload = await response.json();
                            if (payload && payload.success) {
                                if (rolesModal) {
                                    rolesModal.hide();
                                }
                                Swal.fire({
                                    title: 'Operacion exitosa',
                                    text: payload.message || 'Roles asignados exitosamente.',
                                    icon: 'success',
                                    confirmButtonText: 'Continuar'
                                }).then(() => {
                                    window.location.reload();
                                });
                                return;
                            }
                        }

                        // When the server returns HTML it represents validation/errors and keeps the modal open.
                        const html = await response.text();
                        rolesModalBody.innerHTML = html;
                        initializeAssignRolesModal();
                    } catch {
                        Swal.fire({
                            title: 'Error',
                            text: 'No fue posible actualizar los roles. Intenta nuevamente.',
                            icon: 'error',
                            confirmButtonText: 'Entendido'
                        });
                    }
                });
            }

            async function openRolesModal(usuarioId, usuarioNombre) {
                if (!rolesModal || !rolesModalBody || !modalTitle) {
                    return;
                }

                modalTitle.textContent = `Gestionar roles: ${usuarioNombre}`;
                rolesModalBody.innerHTML = `
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                    </div>`;
                rolesModal.show();

                try {
                    const response = await fetch(`/seguridad/usuarios/${usuarioId}/roles/modal`, {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    rolesModalBody.innerHTML = await response.text();
                    initializeAssignRolesModal();
                } catch {
                    rolesModalBody.innerHTML = '<div class="alert alert-danger mb-0">No fue posible cargar la gestion de roles.</div>';
                }
            }

            document.querySelectorAll('.js-open-roles-modal').forEach(button => {
                button.addEventListener('click', function () {
                    const usuarioId = Number(this.dataset.usuarioId);
                    const usuarioNombre = this.dataset.usuario || 'Usuario';
                    openRolesModal(usuarioId, usuarioNombre);
                });
            });

            if (openRolesForUserId) {
                const autoButton = document.querySelector(`.js-open-roles-modal[data-usuario-id="${openRolesForUserId}"]`);
                if (autoButton) {
                    autoButton.click();
                }
            }
        });
    </script>
}
