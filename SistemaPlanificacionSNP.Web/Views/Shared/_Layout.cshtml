<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Sistema de Planificación SNP</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome (Versión más estable) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <!-- Sweet Alert 2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.5/dist/sweetalert2.all.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.5/dist/sweetalert2.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/custom.css">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light" style="font-family: 'Inter', sans-serif;">

    <!-- Contenedor Principal Flex -->
    <div class="wrapper d-flex flex-column min-vh-100">

        <!-- Navbar Superior (Header) -->
        <header class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top shadow-sm py-2">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center fw-bold text-primary" href="/">
                    <i class="fas fa-chart-line fs-4 me-2"></i>
                    <span style="letter-spacing: 0.5px;">SNP</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center text-dark fw-medium" href="#" id="userMenu" role="button" data-bs-toggle="dropdown">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                                    <i class="fas fa-user"></i>
                                </div>
                                <span id="usuarioNombre">@(User?.Identity?.Name ?? "Usuario")</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 rounded-3" aria-labelledby="userMenu">
                                <li><a class="dropdown-item py-2" href="/account/profile"><i class="fas fa-user-circle me-2 text-muted"></i> Mi Perfil</a></li>
                                <li><a class="dropdown-item py-2" href="/account/changepassword"><i class="fas fa-key me-2 text-muted"></i> Cambiar Contraseña</a></li>


                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="#" onclick="logout()"><i class="fas fa-sign-out-alt me-2"></i> Cerrar Sesión</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Área de Contenido Central -->
        <div class="container-fluid flex-grow-1">
            <div class="row h-100">

                <!-- Sidebar Lateral (Aside) -->
                <aside class="col-md-2 d-none d-md-block bg-white border-end sidebar py-4" style="min-height: calc(100vh - 65px);">
                    <div class="position-sticky" style="top: 85px;">
                        <div class="text-uppercase text-muted fw-bold mb-3 px-3" style="font-size: 0.75rem; letter-spacing: 1px;">
                            Navegación Principal
                        </div>
                        <div id="menu-container" class="px-2">
                            <div class="text-center mb-4">
                                <div class="spinner-border spinner-border-sm text-primary" role="status">
                                    <span class="visually-hidden">Cargando menú...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </aside>

                <!-- Contenido Principal (Main) -->
                <main class="col-md-10 ms-sm-auto px-md-4 py-4">

                    <!-- Alertas Globales -->
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success border-0 shadow-sm rounded-3 alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="fas fa-check-circle fs-5 me-2"></i>
                            <div>@ViewBag.Success</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger border-0 shadow-sm rounded-3 alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="fas fa-exclamation-circle fs-5 me-2"></i>
                            <div>@ViewBag.Error</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (ViewBag.Warning != null)
                    {
                        <div class="alert alert-warning border-0 shadow-sm rounded-3 alert-dismissible fade show d-flex align-items-center" role="alert">
                            <i class="fas fa-exclamation-triangle fs-5 me-2"></i>
                            <div>@ViewBag.Warning</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Renderizado de la Vista Actual -->
                    @RenderBody()

                </main>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <footer class="bg-white text-center py-3 border-top mt-auto">
        <div class="container-fluid">
            <p class="mb-0 text-muted" style="font-size: 0.85rem;">&copy; 2026 Sistema Integral de Planificación e Inversión Pública. Todos los derechos reservados.</p>
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

    <!-- Custom JS -->
    <script src="~/js/app.js"></script>
    <script src="~/js/auth.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof loadUserInfo === 'function') loadUserInfo();
                if (typeof loadDynamicMenu === 'function') loadDynamicMenu();
            });
    </script>
</body>
</html>
```