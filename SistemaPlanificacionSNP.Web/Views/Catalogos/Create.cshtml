@model SistemaPlanificacionSNP.Web.Models.CatalogoCreateViewModel

@{
    ViewData["Title"] = "Crear Catálogo";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-plus-circle me-2 text-primary"></i>Nuevo Catálogo Maestro</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Registro de una nueva lista paramétrica para el sistema.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/parametrizacion/catalogos" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-xl-8 col-xxl-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex align-items-center">
                    <div class="rounded-3 p-2 d-flex align-items-center justify-content-center me-3" style="background-color: #eff6ff; color: #3b82f6;">
                        <i class="fas fa-list-ul fs-5"></i>
                    </div>
                    <h5 class="mb-0 fw-bold text-dark">Datos del Catálogo</h5>
                </div>
                <div class="card-body p-4 p-xl-5">
                    <form method="post" action="/parametrizacion/catalogos/crear" id="formCreateCatalogo">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger border-0 border-start border-4 border-danger shadow-sm rounded-3 mb-4" role="alert">
                                <div class="d-flex">
                                    <i class="fas fa-exclamation-circle mt-1 me-3 fs-5 text-danger"></i>
                                    <div>
                                        <h6 class="fw-bold mb-1 text-danger">Error de validación</h6>
                                        <div asp-validation-summary="All" class="text-danger small mb-0 ps-3"></div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="mb-4">
                            <label asp-for="Codigo" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Código Único <span class="text-danger">*</span></label>
                            <input asp-for="Codigo" class="form-control form-control-lg bg-light border-light-subtle" placeholder="Ej. TIPO_TERRITORIO" style="text-transform: uppercase;" autocomplete="off" />
                            <div class="form-text text-muted text-xs mt-2"><i class="fas fa-info-circle me-1 text-primary"></i>Debe ser único, sin espacios y preferiblemente en mayúsculas y guiones bajos.</div>
                            <span asp-validation-for="Codigo" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Nombre" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Nombre del Catálogo <span class="text-danger">*</span></label>
                            <input asp-for="Nombre" class="form-control form-control-lg" placeholder="Ej. Tipos de Territorio Nacional" autocomplete="off" />
                            <span asp-validation-for="Nombre" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Descripcion" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Propósito o uso de este catálogo dentro del sistema..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                        </div>

                        <hr class="border-light-subtle my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/parametrizacion/catalogos" class="btn btn-outline-secondary px-4 rounded-pill">Cancelar</a>
                            <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm" id="btnSubmit">
                                <i class="fas fa-save me-2"></i>Guardar Catálogo
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4 col-xxl-4 d-none d-xl-block">
            <div class="card border-0 shadow-sm bg-light h-100">
                <div class="card-body p-4 p-xl-5">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px; color: #f59e0b;">
                            <i class="fas fa-lightbulb fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">¿Qué es un Catálogo?</h5>
                    </div>
                    <div class="bg-white p-4 rounded-3 shadow-sm border border-light-subtle">
                        <p class="text-muted text-sm mb-3">
                            Los catálogos son listas desplegables y parámetros base que alimentan todo el sistema.
                        </p>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-3 d-flex align-items-start">
                                <i class="fas fa-check-circle text-success mt-1 me-3"></i>
                                <div>
                                    <span class="fw-bold text-dark d-block text-sm">Escalabilidad</span>
                                    <span class="text-muted text-xs">Evitan modificar el código cuando hay nuevos tipos o estados.</span>
                                </div>
                            </li>
                            <li class="d-flex align-items-start">
                                <i class="fas fa-check-circle text-success mt-1 me-3"></i>
                                <div>
                                    <span class="fw-bold text-dark d-block text-sm">Ítems</span>
                                    <span class="text-muted text-xs">Una vez creado, podrás agregarle valores específicos desde la pantalla de detalle.</span>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Scripts estándar de validación de ASP.NET Core MVC (Se asume que existen en el layout o aquí) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const inputCodigo = document.getElementById('Codigo');
            const form = document.getElementById('formCreateCatalogo');
            const btnSubmit = document.getElementById('btnSubmit');

            // Forzar formato correcto en el Código
            if (inputCodigo) {
                inputCodigo.addEventListener('input', function(e) {
                    let val = this.value.toUpperCase();
                    // Reemplazar espacios por guiones bajos
                    val = val.replace(/\s+/g, '_');
                    // Remover caracteres que no sean letras, números o guiones bajos
                    val = val.replace(/[^A-Z0-9_]/g, '');
                    this.value = val;
                });
            }

            // Evitar envíos dobles y mostrar animación
            if (form) {
                form.addEventListener('submit', function(e) {
                    // Validar si jQuery Validator aprueba el formulario
                    if ($(this).valid()) {
                        btnSubmit.disabled = true;
                        btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Guardando...';
                    }
                });
            }
        });
    </script>
}