@model SistemaPlanificacionSNP.Web.Models.CatalogoApiDto
@using System.Text.Json

@{
    ViewData["Title"] = $"Catálogo: {Model.Nombre}";
    var nuevoItemModel = new SistemaPlanificacionSNP.Web.Models.ItemCatalogoCreateViewModel
    {
        CatalogoId = Model.CatalogoId,
        CatalogoCodigo = Model.Codigo,
        Orden = Model.Items.Count + 1
    };
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-layer-group me-2 text-primary"></i>Detalle de Catálogo</h3>
            <p class="text-muted mb-0 text-uppercase tracking-wider text-xs fw-bold">@Model.Codigo</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/parametrizacion/catalogos" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4">
                    <h5 class="mb-0 fw-bold text-dark">Información Maestra</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="text-muted text-xs text-uppercase fw-bold tracking-wider mb-1">Nombre</label>
                        <div class="fw-semibold fs-5 text-dark">@Model.Nombre</div>
                    </div>
                    <div class="mb-4">
                        <label class="text-muted text-xs text-uppercase fw-bold tracking-wider mb-1">Descripción</label>
                        <div class="text-secondary">@(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción" : Model.Descripcion)</div>
                    </div>
                    <div class="mb-4">
                        <label class="text-muted text-xs text-uppercase fw-bold tracking-wider mb-1">Total Ítems Activos</label>
                        <div class="fs-4 fw-bolder text-primary">@Model.Items.Count</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-tags me-2 text-primary"></i>Valores del Catálogo (Ítems)</h5>
                    <button type="button" class="btn btn-sm btn-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addItemModal">
                        <i class="fas fa-plus me-1"></i> Agregar Ítem
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 border-0 text-xs text-muted fw-bold">ORDEN</th>
                                    <th class="border-0 text-xs text-muted fw-bold">CÓDIGO INTERNO</th>
                                    <th class="border-0 text-xs text-muted fw-bold">VALOR / NOMBRE</th>
                                    <th class="pe-4 border-0 text-xs text-muted fw-bold text-end">ESTADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Items.Count == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">Este catálogo aún no tiene ítems configurados.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.Items.OrderBy(i => i.Orden))
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-muted">@item.Orden</td>
                                            <td class="text-xs fw-bold tracking-wider text-secondary">@item.Codigo</td>
                                            <td class="fw-semibold text-dark">
                                                @item.Nombre
                                                @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                                {
                                                    <div class="text-muted text-xs fw-normal mt-1">@item.Descripcion</div>
                                                }
                                            </td>
                                            <td class="pe-4 text-end">
                                                <i class="fas fa-check-circle text-success fs-5"></i>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold text-dark"><i class="fas fa-plus-circle me-2 text-primary"></i>Nuevo Ítem</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/parametrizacion/catalogos/@Model.Codigo/items">
                @Html.AntiForgeryToken()
                <input type="hidden" name="CatalogoId" value="@nuevoItemModel.CatalogoId" />
                <input type="hidden" name="CatalogoCodigo" value="@nuevoItemModel.CatalogoCodigo" />

                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium text-sm">Código del Ítem</label>
                        <input type="text" name="Codigo" class="form-control" required placeholder="Ej. INACTIVO, ZONA_NORTE..." style="text-transform: uppercase;" />
                        <div class="form-text text-xs">Código identificador único (sin espacios).</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium text-sm">Valor / Nombre a Mostrar</label>
                        <input type="text" name="Nombre" class="form-control" required placeholder="Ej. En Revisión" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium text-sm">Descripción (Opcional)</label>
                        <textarea name="Descripcion" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-medium text-sm">Orden de visualización</label>
                        <input type="number" name="Orden" class="form-control" value="@nuevoItemModel.Orden" required min="1" />
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm"><i class="fas fa-save me-1"></i> Guardar Ítem</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));

            if (swalSuccess) {
                Swal.fire({ title: '¡Guardado!', text: swalSuccess, icon: 'success', confirmButtonText: 'Continuar' });
            } else if (swalWarning) {
                Swal.fire({ title: 'No procesado', text: swalWarning, icon: 'warning', confirmButtonText: 'Revisar' });
            }
        });
    </script>
}