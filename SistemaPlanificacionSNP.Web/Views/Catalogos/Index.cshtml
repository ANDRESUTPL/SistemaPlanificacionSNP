@model SistemaPlanificacionSNP.Web.Models.CatalogosIndexViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Catálogos del Sistema";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-list-alt me-2 text-primary"></i>Gestión de Catálogos</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Administración de listas desplegables y paramétricos base.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/parametrizacion/catalogos/crear" class="btn btn-secondary border shadow-sm px-4 fw-medium">
                <i class="fas fa-plus me-2"></i>Nuevo Catálogo
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <form method="get" action="/parametrizacion/catalogos" class="row g-3 align-items-end">
                <div class="col-12 col-lg-8">
                    <label class="form-label fw-medium">Buscar catálogo</label>
                    <input type="text" name="buscar" value="@Model.Buscar" class="form-control" placeholder="Buscar por código o nombre..." />
                </div>
                <div class="col-12 col-md-4 col-lg-4 d-grid">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="fas fa-search me-1"></i> Buscar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent pt-4 pb-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-database me-2 text-primary"></i>Catálogos Maestros</h6>
            <span class="badge rounded-pill text-bg-light border">@Model.Catalogos.Count registro(s)</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr>
                            <th class="ps-4 border-0 text-xs text-muted fw-bold">CÓDIGO</th>
                            <th class="border-0 text-xs text-muted fw-bold">NOMBRE Y DESCRIPCIÓN</th>
                            <th class="border-0 text-xs text-muted fw-bold text-center">ÍTEMS</th>
                            <th class="border-0 text-xs text-muted fw-bold text-center">ESTADO</th>
                            <th class="pe-4 border-0 text-xs text-muted fw-bold text-end">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Catalogos.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fas fa-folder-open fs-2 mb-3 text-secondary opacity-50"></i>
                                    <p class="mb-0">No se encontraron catálogos registrados.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var cat in Model.Catalogos)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary text-xs tracking-wider">@cat.Codigo</td>
                                    <td>
                                        <div class="fw-semibold text-dark">@cat.Nombre</div>
                                        <div class="text-muted text-truncate" style="font-size: 0.85rem; max-width: 300px;">@cat.Descripcion</div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle">
                                            @cat.Items.Count
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (cat.Activo)
                                        {
                                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger-subtle">Inactivo</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a href="/parametrizacion/catalogos/@cat.Codigo" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="fas fa-cog me-1"></i>Gestionar Ítems
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));

            if (swalSuccess) {
                Swal.fire({ title: '¡Éxito!', text: swalSuccess, icon: 'success', confirmButtonText: 'Continuar' });
            } else if (swalWarning) {
                Swal.fire({ title: 'Atención', text: swalWarning, icon: 'warning', confirmButtonText: 'Entendido' });
            }
        });
    </script>
}