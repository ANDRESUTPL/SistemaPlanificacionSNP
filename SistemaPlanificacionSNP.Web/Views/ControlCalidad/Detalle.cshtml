@model SistemaPlanificacionSNP.Web.Models.RevisioneApiDto
@using System.Text.Json

@{
    ViewData["Title"] = "Detalle de la Revisión Técnica";
    var nuevaAuditoria = new SistemaPlanificacionSNP.Web.Models.AuditoriaCreateViewModel { RevisionId = Model.RevisionId };
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-search-location me-2 text-primary"></i>Expediente de Revisión</h3>
            <p class="text-muted mb-0 text-uppercase tracking-wider text-xs fw-bold">@Model.CodigoRevision</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/controlcalidad/revisiones" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(to bottom, #ffffff 0%, #f8fafc 100%);">
                <div class="card-body p-4">
                    <div class="text-center mb-4 pb-4 border-bottom">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle mb-3" style="width: 80px; height: 80px; color: #3b82f6;">
                            <i class="fas fa-file-contract fs-1"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">@Model.Modulo</h5>
                        <div class="badge bg-light text-dark border px-3 py-2 mt-2 text-sm">
                            <i class="far fa-clock me-1 text-muted"></i> Registrado: @Model.FechaRevision.ToString("dd MMM yyyy, HH:mm")
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted text-xs text-uppercase fw-bold tracking-wider mb-1">Dictamen Actual</label>
                        <div>
                            @if (Model.Estado == "Pendiente")
                            {
                                <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning border border-warning-subtle px-3 py-1 fs-6">@Model.Estado</span>
                            }
                            else if (Model.Estado == "Rechazada")
                            {
                                <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger-subtle px-3 py-1 fs-6">@Model.Estado</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-1 fs-6">@Model.Estado</span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
                    {
                        <div class="mb-4">
                            <label class="text-muted text-xs text-uppercase fw-bold tracking-wider mb-1">Observaciones</label>
                            <p class="text-secondary text-sm bg-white p-3 rounded border border-light-subtle shadow-sm">@Model.Observaciones</p>
                        </div>
                    }

                    <div class="alert alert-primary bg-opacity-10 border-0 text-sm mt-auto mb-0">
                        <i class="fas fa-info-circle me-2"></i>Las auditorías generadas registrarán automáticamente el responsable a partir de la sesión.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm mb-4 h-100">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-tasks me-2 text-primary"></i>Historial de Auditorías Anexas</h5>
                    <button type="button" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#addAuditoriaModal">
                        <i class="fas fa-plus me-1"></i> Anexar Auditoría
                    </button>
                </div>
                <div class="card-body p-4 bg-light bg-opacity-50">

                    @if (Model.Auditorias.Count == 0)
                    {
                        <div class="text-center py-5">
                            <div class="display-1 text-muted opacity-25 mb-3"><i class="fas fa-stamp"></i></div>
                            <h5 class="text-muted fw-bold">Sin auditorías registradas</h5>
                            <p class="text-muted">Aún no se han ejecutado controles de calidad específicos para este expediente.</p>
                            <button type="button" class="btn btn-outline-primary mt-2" data-bs-toggle="modal" data-bs-target="#addAuditoriaModal">Registrar Primera Auditoría</button>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive bg-white rounded-3 shadow-sm border border-light-subtle">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-0 text-xs text-muted fw-bold ps-4">TIPO / FECHA</th>
                                        <th class="border-0 text-xs text-muted fw-bold">RESPONSABLE</th>
                                        <th class="border-0 text-xs text-muted fw-bold text-center">RESULTADO</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var aud in Model.Auditorias.OrderByDescending(a => a.FechaRegistro))
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="fw-bold text-dark mb-1">@aud.Tipo</div>
                                                <div class="text-muted text-xs"><i class="far fa-calendar-check me-1"></i> @aud.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</div>
                                            </td>
                                            <td class="fw-medium text-secondary">
                                                <i class="fas fa-user-circle me-1 text-muted"></i> @aud.Responsable
                                            </td>
                                            <td class="text-center">
                                                @if (aud.Resultado == "Conforme")
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-1">@aud.Resultado</span>
                                                }
                                                else if (aud.Resultado == "No Conforme")
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-3 py-1">@aud.Resultado</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle px-3 py-1">@aud.Resultado</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addAuditoriaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold text-dark"><i class="fas fa-stamp me-2 text-primary"></i>Registrar Auditoría</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/controlcalidad/revisiones/auditorias/crear">
                @Html.AntiForgeryToken()
                <input type="hidden" name="RevisionId" value="@nuevaAuditoria.RevisionId" />

                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium text-sm">Tipo de Auditoría</label>
                        <select name="Tipo" class="form-select" required>
                            <option value="">-- Seleccionar --</option>
                            <option value="Interna">Auditoría Interna</option>
                            <option value="Externa">Auditoría Externa</option>
                            <option value="Seguimiento">Control de Seguimiento</option>
                            <option value="Cumplimiento">Revisión de Cumplimiento</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium text-sm">Resultado del Dictamen</label>
                        <select name="Resultado" class="form-select" required>
                            <option value="">-- Seleccionar --</option>
                            <option value="Conforme">Conforme (Aprobado)</option>
                            <option value="Observado">Observado (Requiere ajustes)</option>
                            <option value="No Conforme">No Conforme (Rechazado)</option>
                        </select>
                    </div>
                    <div class="alert alert-info border-0 text-xs mb-0 mt-4">
                        <i class="fas fa-info-circle me-1"></i> Su usuario quedará grabado permanentemente como responsable de esta acción técnica.
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm"><i class="fas fa-save me-1"></i> Guardar Acta</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));

            if (swalSuccess) Swal.fire({ title: '¡Guardado!', text: swalSuccess, icon: 'success', confirmButtonText: 'Continuar' });
            if (swalWarning) Swal.fire({ title: 'Alerta', text: swalWarning, icon: 'warning', confirmButtonText: 'Revisar' });
        });
    </script>
}