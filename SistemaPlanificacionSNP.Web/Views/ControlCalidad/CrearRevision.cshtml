@model SistemaPlanificacionSNP.Web.Models.RevisionCreateViewModel

@{
    ViewData["Title"] = "Nueva Revisión";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-file-signature text-primary me-2"></i>Apertura de Revisión</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Registro para iniciar el control de calidad de un módulo o entidad.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/controlcalidad/revisiones" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex align-items-center">
                    <div class="rounded-3 p-2 d-flex align-items-center justify-content-center me-3" style="background-color: #eff6ff; color: #3b82f6;">
                        <i class="fas fa-clipboard-list fs-5"></i>
                    </div>
                    <h5 class="mb-0 fw-bold text-dark">Información de la Revisión</h5>
                </div>
                <div class="card-body p-4 p-xl-5">
                    <form method="post" action="/controlcalidad/revisiones/crear" id="formCreateRev">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger border-0 border-start border-4 border-danger shadow-sm rounded-3 mb-4 d-flex" role="alert">
                                <i class="fas fa-exclamation-circle mt-1 me-3 fs-5 text-danger"></i>
                                <div>
                                    <h6 class="fw-bold mb-1 text-danger">Revisa los campos</h6>
                                    <div asp-validation-summary="All" class="text-danger small mb-0 ps-3"></div>
                                </div>
                            </div>
                        }

                        <div class="row g-4 mb-4">
                            <div class="col-12 col-md-6">
                                <label asp-for="CodigoRevision" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Código Único (Nomenclatura) <span class="text-danger">*</span></label>
                                <input asp-for="CodigoRevision" class="form-control form-control-lg bg-light" placeholder="Ej. REV-PEI-2026-001" autocomplete="off" style="text-transform: uppercase;" />
                                <span asp-validation-for="CodigoRevision" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="Estado" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Estado Inicial <span class="text-danger">*</span></label>
                                <select asp-for="Estado" class="form-select form-select-lg">
                                    <option value="Pendiente">Pendiente</option>
                                    <option value="Aprobada">Aprobada</option>
                                    <option value="Rechazada">Rechazada</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Modulo" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Módulo / Objeto de Revisión <span class="text-danger">*</span></label>
                            <input asp-for="Modulo" class="form-control form-control-lg" placeholder="Ej. Plan Estratégico Ministerio de Salud" autocomplete="off" />
                            <span asp-validation-for="Modulo" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Observaciones" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Observaciones Generales</label>
                            <textarea asp-for="Observaciones" class="form-control" rows="3" placeholder="Anotaciones preliminares..."></textarea>
                            <span asp-validation-for="Observaciones" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                        </div>

                        <hr class="border-light-subtle my-5">

                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit" class="btn btn-secondary px-5 rounded-pill shadow-sm" id="btnSubmit">
                                <i class="fas fa-save me-2"></i>Aperturar Revisión
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        document.getElementById('formCreateRev').addEventListener('submit', function(e) {
            if ($(this).valid()) {
                const btn = document.getElementById('btnSubmit');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Procesando...';
            }
        });
    </script>
}