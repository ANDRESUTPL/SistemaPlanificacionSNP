@model SistemaPlanificacionSNP.Web.Models.PlanesEstrategicoDetailApiDto
@using System.Text.Json

@{
    ViewData["Title"] = "Detalle del PEI y Proyectos";
    var nuevoProyecto = new SistemaPlanificacionSNP.Web.Models.ProyectoInversionCreateViewModel { PlanEstrategicoId = Model.PlanEstrategicoId };
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-folder-open me-2 text-primary"></i>Plan Estratégico y Proyectos</h3>
            <p class="text-muted mb-0 text-uppercase tracking-wider text-xs fw-bold">PEI-@Model.PlanEstrategicoId</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/planificacion/institucional" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Panel Izquierdo: Resumen del PEI -->
        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm h-100" style="background: linear-gradient(to bottom, #ffffff 0%, #f8fafc 100%);">
                <div class="card-body p-4">
                    <div class="text-center mb-4 pb-4 border-bottom">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle mb-3" style="width: 80px; height: 80px; color: #3b82f6;">
                            <i class="fas fa-building fs-1"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">@Model.Entidad</h5>
                        <div class="badge bg-light text-dark border px-3 py-2 mt-2 text-sm">
                            <i class="far fa-calendar-alt me-1 text-muted"></i> Período: @Model.PeriodoInicio - @Model.PeriodoFin
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted text-xs text-uppercase fw-bold tracking-wider mb-1">Estado de Formulación</label>
                        <div>
                            @if (Model.Estado == "Borrador")
                            {
                                <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning border border-warning-subtle px-3 py-1 fs-6">@Model.Estado</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-1 fs-6">@Model.Estado</span>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted text-xs text-uppercase fw-bold tracking-wider mb-1">Inversión Total Programada</label>
                        <div class="fs-2 fw-bolder text-primary">@Model.Proyectos.Sum(p => p.Monto).ToString("C0")</div>
                    </div>

                    <div class="alert alert-primary bg-opacity-10 border-0 text-sm mt-auto mb-0">
                        <i class="fas fa-lightbulb me-2"></i>Los proyectos creados aquí deberán someterse a control de calidad y alineación estratégica.
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel Derecho: Cartera de Proyectos -->
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm mb-4 h-100">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-project-diagram me-2 text-primary"></i>Cartera de Proyectos de Inversión</h5>
                    <button type="button" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#addProyectoModal">
                        <i class="fas fa-plus me-1"></i> Formular Proyecto
                    </button>
                </div>
                <div class="card-body p-4 bg-light bg-opacity-50">

                    @if (Model.Proyectos.Count == 0)
                    {
                        <div class="text-center py-5">
                            <div class="display-1 text-muted opacity-25 mb-3"><i class="fas fa-coins"></i></div>
                            <h5 class="text-muted fw-bold">Cartera vacía</h5>
                            <p class="text-muted">La institución aún no ha formulado proyectos de inversión para este período.</p>
                            <button type="button" class="btn btn-outline-primary mt-2" data-bs-toggle="modal" data-bs-target="#addProyectoModal">Crear Primer Proyecto</button>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive bg-white rounded-3 shadow-sm border border-light-subtle">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-0 text-xs text-muted fw-bold ps-4">CÓDIGO / PROYECTO</th>
                                        <th class="border-0 text-xs text-muted fw-bold text-end">MONTO ($)</th>
                                        <th class="border-0 text-xs text-muted fw-bold text-center">ESTADO</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var proy in Model.Proyectos.OrderBy(p => p.CodigoProyecto))
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="text-xs fw-bold text-primary tracking-wider mb-1">CUP: @proy.CodigoProyecto</div>
                                                <div class="fw-semibold text-dark">@proy.Nombre</div>
                                            </td>
                                            <td class="text-end fw-bold text-secondary">
                                                @proy.Monto.ToString("N2")
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-light text-dark border">@proy.Estado</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para Crear Proyecto -->
<div class="modal fade" id="addProyectoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold text-dark"><i class="fas fa-file-invoice-dollar me-2 text-primary"></i>Formular Proyecto de Inversión</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/planificacion/institucional/proyectos/crear">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PlanEstrategicoId" value="@nuevoProyecto.PlanEstrategicoId" />

                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-medium text-sm">CUP (Cód. Único de Proyecto)</label>
                            <input type="text" name="CodigoProyecto" class="form-control fw-bold text-primary bg-light" required placeholder="Ej. PRY-2026-001" style="text-transform: uppercase;" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-medium text-sm">Presupuesto Asignado ($)</label>
                            <input type="number" step="0.01" min="0.01" name="Monto" class="form-control" required placeholder="Ej. 150000.00" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium text-sm">Nombre Oficial del Proyecto</label>
                            <input type="text" name="Nombre" class="form-control" required placeholder="Ej. Construcción y Equipamiento de Subcentro de Salud..." />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm"><i class="fas fa-save me-1"></i> Guardar Proyecto</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));

            if (swalSuccess) Swal.fire({ title: '¡Guardado!', text: swalSuccess, icon: 'success', confirmButtonText: 'Continuar' });
            if (swalWarning) Swal.fire({ title: 'Alerta', text: swalWarning, icon: 'warning', confirmButtonText: 'Revisar' });
        });
    </script>
}