@model SistemaPlanificacionSNP.Web.Models.PlanificacionIndexViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Planificación Institucional";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-building me-2 text-primary"></i>Planificación Institucional</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Gestión de Planes Estratégicos (PEI) y Proyectos de Inversión.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/planificacion/institucional/crear" class="btn btn-secondary border shadow-sm px-4 fw-medium">
                <i class="fas fa-plus me-2"></i>Nuevo PEI
            </a>
        </div>
    </div>

    <!-- Indicadores del Dashboard -->
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 4px solid #3b82f6;">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Planes Totales</p>
                        <h3 class="mb-0 fw-bolder text-dark">@Model.Dashboard.TotalPlanes</h3>
                    </div>
                    <div class="rounded-circle p-3 bg-primary bg-opacity-10 text-primary"><i class="fas fa-clipboard-list fs-5"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 4px solid #10b981;">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Planes Activos</p>
                        <h3 class="mb-0 fw-bolder text-dark">@Model.Dashboard.TotalPlanesActivos</h3>
                    </div>
                    <div class="rounded-circle p-3 bg-success bg-opacity-10 text-success"><i class="fas fa-check-circle fs-5"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 4px solid #8b5cf6;">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Proyectos</p>
                        <h3 class="mb-0 fw-bolder text-dark">@Model.Dashboard.TotalProyectos</h3>
                    </div>
                    <div class="rounded-circle p-3 bg-opacity-10" style="background-color: rgba(139, 92, 246, 0.1); color: #8b5cf6;"><i class="fas fa-project-diagram fs-5"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 4px solid #f59e0b;">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Inversión Activa</p>
                        <h4 class="mb-0 fw-bolder text-dark">@Model.Dashboard.MontoTotalProyectosActivos.ToString("C0")</h4>
                    </div>
                    <div class="rounded-circle p-3 bg-warning bg-opacity-10 text-warning"><i class="fas fa-dollar-sign fs-5"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Directorio de Planes Institucionales -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-list me-2 text-primary"></i>Directorio de Planes Estratégicos (PEI)</h6>
        </div>

        <div class="card-body p-4 bg-light bg-opacity-50 border-bottom">
            <form method="get" action="/planificacion/institucional" class="row g-2 align-items-center">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="buscar" value="@Model.Buscar" class="form-control border-start-0" placeholder="Buscar por nombre de entidad pública..." />
                    </div>
                </div>
                <div class="col-12 col-md-4 col-lg-2">
                    <button type="submit" class="btn btn-secondary w-100">Buscar</button>
                </div>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-white">
                        <tr>
                            <th class="ps-4 border-0 text-xs text-muted fw-bold">ID / ENTIDAD PÚBLICA</th>
                            <th class="border-0 text-xs text-muted fw-bold text-center">VIGENCIA</th>
                            <th class="border-0 text-xs text-muted fw-bold text-center">ESTADO</th>
                            <th class="pe-4 border-0 text-xs text-muted fw-bold text-end">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Planes.Count == 0)
                        {
                            <tr><td colspan="4" class="text-center py-5 text-muted">No se encontraron Planes Estratégicos registrados.</td></tr>
                        }
                        else
                        {
                            @foreach (var plan in Model.Planes)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-primary text-xs tracking-wider mb-1">PEI-@plan.PlanEstrategicoId</div>
                                        <div class="fw-semibold text-dark">@plan.Entidad</div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border"><i class="far fa-calendar-alt me-1 text-muted"></i> @plan.PeriodoInicio - @plan.PeriodoFin</span>
                                    </td>
                                    <td class="text-center">
                                        @if (plan.Estado == "Borrador")
                                        {
                                            <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning border border-warning-subtle px-3 py-1">@plan.Estado</span>
                                        }
                                        else if (plan.Estado == "Inactivo")
                                        {
                                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger-subtle px-3 py-1">@plan.Estado</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-1">@plan.Estado</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a href="/planificacion/institucional/@plan.PlanEstrategicoId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="fas fa-folder-open me-1"></i>Proyectos
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Paginador simple -->
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white border-top">
                <nav>
                    <ul class="pagination justify-content-end mb-0">
                        <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                            <a class="page-link" href="/planificacion/institucional?buscar=@Model.Buscar&page=@(Model.Page - 1)">Anterior</a>
                        </li>
                        <li class="page-item disabled"><span class="page-link">Página @Model.Page de @Model.TotalPages</span></li>
                        <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="/planificacion/institucional?buscar=@Model.Buscar&page=@(Model.Page + 1)">Siguiente</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));

            if (swalSuccess) Swal.fire({ title: '¡Éxito!', text: swalSuccess, icon: 'success', confirmButtonText: 'Continuar' });
            if (swalWarning) Swal.fire({ title: 'Atención', text: swalWarning, icon: 'warning', confirmButtonText: 'Entendido' });
        });
    </script>
}