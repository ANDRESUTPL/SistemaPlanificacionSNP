@{
    ViewData["Title"] = "Dashboard";
}

<!-- Encabezado de la página -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1 fw-bold text-dark">Panel de Control</h3>
        <p class="text-muted mb-0">Resumen general de planificación e inversión pública.</p>
    </div>
    <div>
        <button class="btn btn-outline-primary btn-sm rounded-pill px-3 shadow-sm" onclick="loadDashboardData()">
            <i class="fas fa-sync-alt me-1"></i> Actualizar
        </button>
    </div>
</div>

<!-- Fila de Widgets (Métricas Principales) -->
<div class="row g-4 mb-4">
    <!-- Planes Activos -->
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 border-0 shadow-sm" style="border-bottom: 3px solid #3b82f6 !important;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Planes Activos</p>
                        <h2 class="mb-0 fw-bolder text-dark" id="planesActivos">
                            <span class="spinner-border spinner-border-sm text-primary"></span>
                        </h2>
                    </div>
                    <div class="rounded-3 p-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 54px; height: 54px; background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); color: #3b82f6;">
                        <i class="fas fa-clipboard-list fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Programas -->
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 border-0 shadow-sm" style="border-bottom: 3px solid #10b981 !important;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Programas</p>
                        <h2 class="mb-0 fw-bolder text-dark" id="totalProgramas">
                            <span class="spinner-border spinner-border-sm text-success"></span>
                        </h2>
                    </div>
                    <div class="rounded-3 p-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 54px; height: 54px; background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); color: #10b981;">
                        <i class="fas fa-layer-group fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Proyectos -->
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 border-0 shadow-sm" style="border-bottom: 3px solid #8b5cf6 !important;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Proyectos</p>
                        <h2 class="mb-0 fw-bolder text-dark" id="totalProyectos">
                            <span class="spinner-border spinner-border-sm" style="color: #8b5cf6;"></span>
                        </h2>
                    </div>
                    <div class="rounded-3 p-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 54px; height: 54px; background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%); color: #8b5cf6;">
                        <i class="fas fa-project-diagram fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Inversión Total -->
    <div class="col-xl-3 col-md-6">
        <div class="card h-100 border-0 shadow-sm" style="border-bottom: 3px solid #f59e0b !important;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Inversión Total</p>
                        <h3 class="mb-0 fw-bolder text-dark" id="inversionTotal" style="font-size: 1.5rem;">
                            <span class="spinner-border spinner-border-sm text-warning"></span>
                        </h3>
                    </div>
                    <div class="rounded-3 p-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 54px; height: 54px; background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); color: #f59e0b;">
                        <i class="fas fa-chart-line fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fila de Gráficos -->
<div class="row g-4 mb-4">
    <!-- Gráfico de Avance -->
    <div class="col-lg-8">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-chart-bar me-2 text-primary"></i> Avance Mensual de Proyectos</h6>
                <div class="dropdown">
                    <button class="btn btn-sm btn-link text-muted p-0" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                        <li><a class="dropdown-item text-xs" href="#"><i class="fas fa-download me-2"></i>Descargar Reporte</a></li>
                    </ul>
                </div>
            </div>
            <div class="card-body">
                <div style="height: 300px; width: 100%;">
                    <canvas id="avanceChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráfico de Estados -->
    <div class="col-lg-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-chart-pie me-2 text-primary"></i> Distribución por Estado</h6>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <div style="height: 250px; width: 100%; position: relative;">
                    <canvas id="estadoChart"></canvas>
                </div>
                <div class="mt-3 text-center text-xs text-muted">
                    Total de planes en ejecución a nivel nacional.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fila de Tabla -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent pt-4 pb-3 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-calendar-alt me-2 text-primary"></i> Planes Próximos a Vencer</h6>
                <a href="#" class="btn btn-sm btn-link text-primary text-decoration-none text-xs fw-medium">Ver todos <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light bg-opacity-50">
                            <tr>
                                <th class="ps-4 border-0 text-xs text-muted fw-bold">PLAN / DESCRIPCIÓN</th>
                                <th class="border-0 text-xs text-muted fw-bold">ENTIDAD</th>
                                <th class="border-0 text-xs text-muted fw-bold text-center">ESTADO</th>
                                <th class="border-0 text-xs text-muted fw-bold">FECHA FIN</th>
                                <th class="pe-4 border-0 text-xs text-muted fw-bold text-end">ACCIONES</th>
                            </tr>
                        </thead>
                        <tbody id="planesBody">
                            <tr>
                                <td colspan="5" class="text-center py-4">
                                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                                    <span class="text-muted text-sm">Cargando información...</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let estadoChart, avanceChart;

        document.addEventListener('DOMContentLoaded', function() {
            loadDashboardData();
        });

        async function loadDashboardData() {
            try {
                // Fetch real a la API
                const response = await fetch('/Dashboard/GetDashboardData');

                if (!response.ok) throw new Error('Error en la respuesta del servidor');

                const result = await response.json();

                if (result.success && result.data) {
                    updateWidgets(result.data);
                    updateCharts(result.data);
                    updateTable(result.data);
                } else {
                    throw new Error('Formato de datos incorrecto');
                }
            } catch (error) {
                console.warn('Usando datos de demostración debido a:', error.message);
                // Si la API falla, mostramos datos de prueba visuales para no dejar la pantalla vacía
                const fakeData = {
                    totalPlanesActivos: 124,
                    totalProgramasPresupuestarios: 45,
                    totalProyectosInversion: 89,
                    inversionTotalAnualizada: 250450000,
                    planesProximo: [
                        { planEstrategicoInstitucionalId: 1, nombre: 'Plan de Desarrollo Vial Norte', descripcion: 'Ampliación y mantenimiento de vías principales', entidadPublicaId: 'Min. de Transporte', estado: 'Activo', fechaFin: '2026-10-15' },
                        { planEstrategicoInstitucionalId: 2, nombre: 'Expansión Red Eléctrica Rural', descripcion: 'Fase 2 de tendido eléctrico y subestaciones', entidadPublicaId: 'Corp. Eléctrica Nacional', estado: 'En Revisión', fechaFin: '2026-11-01' },
                        { planEstrategicoInstitucionalId: 3, nombre: 'Construcción Hospital General', descripcion: 'Equipamiento e infraestructura médica', entidadPublicaId: 'Min. de Salud Pública', estado: 'Completado', fechaFin: '2026-07-20' },
                        { planEstrategicoInstitucionalId: 4, nombre: 'Modernización Escuelas Públicas', descripcion: 'Implementación de laboratorios tecnológicos', entidadPublicaId: 'Min. de Educación', estado: 'Pausado', fechaFin: '2027-02-10' }
                    ]
                };
                updateWidgets(fakeData);
                updateCharts(fakeData);
                updateTable(fakeData);
            }
        }

        function updateWidgets(data) {
            animateValue('planesActivos', 0, data.totalPlanesActivos, 1000);
            animateValue('totalProgramas', 0, data.totalProgramasPresupuestarios, 1000);
            animateValue('totalProyectos', 0, data.totalProyectosInversion, 1000);

            // Para la moneda, la animación es más compleja, la asignamos directo pero formateada
            document.getElementById('inversionTotal').textContent = formatCurrency(data.inversionTotalAnualizada);
        }

        // Función para animar los números incrementando
        function animateValue(id, start, end, duration) {
            if (start === end) return;
            var range = end - start;
            var current = start;
            var increment = end > start ? 1 : -1;
            // Calculamos el paso para no saturar el renderizado (máximo 60 frames)
            var stepTime = Math.abs(Math.floor(duration / Math.min(range, 60)));
            var stepValue = Math.ceil(range / (duration / stepTime));

            var obj = document.getElementById(id);
            var timer = setInterval(function() {
                current += stepValue * increment;
                if ((increment > 0 && current >= end) || (increment < 0 && current <= end)) {
                    current = end;
                    clearInterval(timer);
                }
                // Damos formato de número con separadores de miles
                obj.textContent = new Intl.NumberFormat('es-ES').format(current);
            }, stepTime);
        }

        function updateCharts(data) {
            // Configuración global de Chart.js para que coincida con nuestro CSS
            Chart.defaults.font.family = "'Inter', sans-serif";
            Chart.defaults.color = '#64748b'; // text-muted

            // 1. Gráfico de Estado (Doughnut)
            const estadoCtx = document.getElementById('estadoChart').getContext('2d');

            if (estadoChart) estadoChart.destroy(); // Destruir previo si actualizamos

            estadoChart = new Chart(estadoCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Activos', 'En Revisión', 'Completados', 'Pausados'],
                    datasets: [{
                        data: [
                            Math.floor(data.totalPlanesActivos * 0.55),
                            Math.floor(data.totalPlanesActivos * 0.25),
                            Math.floor(data.totalPlanesActivos * 0.15),
                            Math.floor(data.totalPlanesActivos * 0.05)
                        ],
                        backgroundColor: [
                            '#3b82f6', // primary (blue)
                            '#f59e0b', // warning (amber)
                            '#10b981', // success (emerald)
                            '#ef4444'  // danger (red)
                        ],
                        borderWidth: 2,
                        borderColor: '#ffffff',
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 20,
                                font: { size: 12, weight: '500' }
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(15, 23, 42, 0.9)',
                            padding: 12,
                            cornerRadius: 8,
                            titleFont: { size: 13 },
                            bodyFont: { size: 14, weight: 'bold' }
                        }
                    }
                }
            });

            // 2. Gráfico de Avance (Bar)
            const avanceCtx = document.getElementById('avanceChart').getContext('2d');

            if (avanceChart) avanceChart.destroy();

            avanceChart = new Chart(avanceCtx, {
                type: 'bar',
                data: {
                    labels: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul'],
                    datasets: [
                        {
                            label: 'Ejecución 2026 (%)',
                            data: [15, 25, 32, 45, 58, 65, 72],
                            backgroundColor: '#3b82f6',
                            borderRadius: 6,
                            barPercentage: 0.6
                        },
                        {
                            label: 'Meta Proyectada (%)',
                            data: [20, 30, 40, 50, 60, 70, 80],
                            backgroundColor: '#e2e8f0', // slate-200
                            borderRadius: 6,
                            barPercentage: 0.6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 100,
                            grid: {
                                color: '#f1f5f9',
                                drawBorder: false
                            },
                            ticks: { callback: function(value) { return value + '%' } }
                        },
                        x: {
                            grid: { display: false, drawBorder: false }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            align: 'end',
                            labels: { usePointStyle: true, boxWidth: 8, font: { size: 12 } }
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: 'rgba(15, 23, 42, 0.9)',
                            cornerRadius: 8
                        }
                    },
                    interaction: { mode: 'index', intersect: false }
                }
            });
        }

        function updateTable(data) {
            const tbody = document.getElementById('planesBody');
            tbody.innerHTML = '';

            if (data.planesProximo && data.planesProximo.length > 0) {
                data.planesProximo.forEach(plan => {
                    const statusInfo = getEstadoInfo(plan.estado);
                    const row = document.createElement('tr');

                    row.innerHTML = `
                                <td class="ps-4 py-3">
                                    <div class="fw-bold text-dark text-sm mb-1">${plan.nombre}</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">${plan.descripcion}</div>
                                </td>
                                <td class="py-3">
                                    <span class="text-secondary text-sm fw-medium">${plan.entidadPublicaId}</span>
                                </td>
                                <td class="py-3 text-center">
                                    <span class="badge rounded-pill bg-${statusInfo.color} bg-opacity-10 text-${statusInfo.color} border border-${statusInfo.color}-subtle px-3 py-2 fw-medium text-xs">
                                        <i class="${statusInfo.icon} me-1"></i> ${plan.estado}
                                    </span>
                                </td>
                                <td class="py-3">
                                    <span class="text-dark text-sm"><i class="far fa-calendar text-muted me-1"></i> ${formatDate(plan.fechaFin)}</span>
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <button class="btn btn-sm btn-light border shadow-sm text-primary rounded-circle" style="width: 32px; height: 32px; padding: 0;" title="Ver Detalles" onclick="viewPlan(${plan.planEstrategicoInstitucionalId})">
                                        <i class="fas fa-arrow-right"></i>
                                    </button>
                                </td>
                            `;
                    tbody.appendChild(row);
                });
            } else {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">No se encontraron planes próximos a vencer.</td></tr>';
            }
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('es-EC', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            }).format(value);
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short', year: 'numeric' }).format(date);
        }

        function getEstadoInfo(estado) {
            const estados = {
                'Activo': { color: 'success', icon: 'fas fa-check-circle' },
                'En Revisión': { color: 'warning', icon: 'fas fa-clock' },
                'Completado': { color: 'info', icon: 'fas fa-flag-checkered' },
                'Pausado': { color: 'danger', icon: 'fas fa-pause-circle' }
            };
            return estados[estado] || { color: 'secondary', icon: 'fas fa-circle' };
        }

        function viewPlan(id) {
            // Lógica para redirigir al detalle del plan
            console.log("Ver detalle del plan ID:", id);
        }
    </script>
}