@model SistemaPlanificacionSNP.Web.Models.CatalogoRolesIndexViewModel

@{
    ViewData["Title"] = "Catálogo de Roles";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-user-shield me-2 text-primary"></i>Catálogo de Roles</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Módulo de configuración para administrar tipos de rol del sistema.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/seguridad/catalogo-roles/crear" class="btn btn-primary border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-plus me-2"></i>Nuevo rol
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <form method="get" action="/seguridad/catalogo-roles" class="row g-3 align-items-end">
                <div class="col-12 col-lg-6">
                    <label class="form-label fw-medium">Buscar</label>
                    <input type="text" name="buscar" value="@Model.Buscar" class="form-control" placeholder="Nombre o descripción" />
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label fw-medium">Estado</label>
                    <select class="form-select" name="activo">
                        <option value="">Todos</option>
                        <option value="true" selected="@(Model.Activo == true)">Activos</option>
                        <option value="false" selected="@(Model.Activo == false)">Inactivos</option>
                    </select>
                </div>

                <div class="col-12 col-md-2 col-lg-3 d-grid">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-filter me-1"></i>Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent pt-4 pb-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-list me-2 text-primary"></i>Listado de Roles</h6>
            <span class="badge rounded-pill text-bg-light border">@Model.Roles.Count registro(s)</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light bg-opacity-50">
                        <tr>
                            <th class="ps-4 border-0 text-xs text-muted fw-bold">NOMBRE</th>
                            <th class="border-0 text-xs text-muted fw-bold">DESCRIPCIÓN</th>
                            <th class="border-0 text-xs text-muted fw-bold">ESTADO</th>
                            <th class="border-0 text-xs text-muted fw-bold">USUARIOS ASIGNADOS</th>
                            <th class="pe-4 border-0 text-xs text-muted fw-bold text-end">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Roles.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No se encontraron roles para los filtros aplicados.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var rol in Model.Roles)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold text-dark">@rol.Nombre</td>
                                    <td>@rol.Descripcion</td>
                                    <td>
                                        @if (rol.Activo)
                                        {
                                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger-subtle">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill text-bg-light border">@rol.UsuariosAsignados</span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-inline-flex gap-2">
                                            <a href="/seguridad/catalogo-roles/@rol.RolId" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                                <i class="fas fa-eye me-1"></i>Ver
                                            </a>
                                            <a href="/seguridad/catalogo-roles/@rol.RolId/editar" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                <i class="fas fa-pen me-1"></i>Editar
                                            </a>

                                            @if (rol.Activo)
                                            {
                                                <form method="post" action="/seguridad/catalogo-roles/@rol.RolId/desactivar" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                                        <i class="fas fa-ban me-1"></i>Desactivar
                                                    </button>
                                                </form>
                                            }

                                            <form method="post" action="/seguridad/catalogo-roles/@rol.RolId/eliminar" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                    <i class="fas fa-trash me-1"></i>Eliminar
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
