@model SistemaPlanificacionSNP.Web.Models.CatalogoRolEditViewModel

@{
    ViewData["Title"] = "Detalle de Rol";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-id-badge me-2 text-primary"></i>Detalle de Rol</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Consulta de información del rol.</p>
        </div>
        <a href="/seguridad/catalogo-roles" class="btn btn-outline-secondary rounded-pill px-3">
            <i class="fas fa-arrow-left me-1"></i>Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">Nombre</dt>
                <dd class="col-sm-9 fw-semibold text-dark">@Model.Nombre</dd>

                <dt class="col-sm-3 text-muted">Descripción</dt>
                <dd class="col-sm-9">@Model.Descripcion</dd>

                <dt class="col-sm-3 text-muted">Estado</dt>
                <dd class="col-sm-9">
                    @if (Model.Activo)
                    {
                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle">Activo</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger-subtle">Inactivo</span>
                    }
                </dd>
            </dl>

            <div class="card border-0 bg-light bg-opacity-50 mt-4 mb-0">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-table-cells me-2 text-primary"></i>Matriz de permisos</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 border-0 text-xs text-muted fw-bold">PANTALLA</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">LECTURA</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">ESCRITURA / CREACIÓN</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">EDICIÓN</th>
                                    <th class="pe-4 border-0 text-xs text-muted fw-bold text-center">ELIMINACIÓN</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var permiso in Model.PermisosPantalla)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-semibold text-dark">@permiso.NombrePantalla</div>
                                            <div class="text-muted" style="font-size: 0.85rem;">@permiso.Ruta</div>
                                        </td>
                                        <td class="text-center">@(permiso.Lectura ? "Sí" : "No")</td>
                                        <td class="text-center">@(permiso.Creacion ? "Sí" : "No")</td>
                                        <td class="text-center">@(permiso.Edicion ? "Sí" : "No")</td>
                                        <td class="pe-4 text-center">@(permiso.Eliminacion ? "Sí" : "No")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex justify-content-end gap-2">
                <a href="/seguridad/catalogo-roles/@Model.RolId/editar" class="btn btn-primary">
                    <i class="fas fa-pen me-1"></i>Editar
                </a>
            </div>
        </div>
    </div>
</div>
