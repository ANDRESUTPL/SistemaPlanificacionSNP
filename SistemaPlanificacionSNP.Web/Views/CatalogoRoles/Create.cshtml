@model SistemaPlanificacionSNP.Web.Models.CatalogoRolCreateViewModel

@{
    ViewData["Title"] = "Crear Rol";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-plus-circle me-2 text-primary"></i>Crear Rol</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Crea un nuevo tipo de rol para el sistema.</p>
        </div>
        <a href="/seguridad/catalogo-roles" class="btn btn-outline-secondary rounded-pill px-3">
            <i class="fas fa-arrow-left me-1"></i>Volver
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form method="post" action="/seguridad/catalogo-roles/crear">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-medium"></label>
                    <input asp-for="Nombre" class="form-control" maxlength="100" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label fw-medium"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="4" maxlength="500"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="Activo" class="form-check-input" type="checkbox" />
                    <label asp-for="Activo" class="form-check-label"></label>
                </div>

                <div class="card border-0 bg-light bg-opacity-50 mb-4">
                    <div class="card-header bg-white border-bottom">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-table-cells me-2 text-primary"></i>Matriz de permisos por pantalla</h6>
                                <small class="text-muted">Define los accesos del rol para cada pantalla disponible.</small>
                            </div>
                            <span class="badge rounded-pill text-bg-light border">@Model.PermisosPantalla.Count pantalla(s)</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light bg-opacity-50">
                                    <tr>
                                        <th class="ps-4 border-0 text-xs text-muted fw-bold">PANTALLA</th>
                                        <th class="border-0 text-xs text-muted fw-bold text-center">LECTURA</th>
                                        <th class="border-0 text-xs text-muted fw-bold text-center">ESCRITURA / CREACIÓN</th>
                                        <th class="border-0 text-xs text-muted fw-bold text-center">EDICIÓN</th>
                                        <th class="pe-4 border-0 text-xs text-muted fw-bold text-center">ELIMINACIÓN</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < Model.PermisosPantalla.Count; i++)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <input type="hidden" asp-for="PermisosPantalla[i].PantallaId" />
                                                <input type="hidden" asp-for="PermisosPantalla[i].NombrePantalla" />
                                                <input type="hidden" asp-for="PermisosPantalla[i].Ruta" />
                                                <input type="hidden" asp-for="PermisosPantalla[i].Icono" />
                                                <input type="hidden" asp-for="PermisosPantalla[i].Orden" />
                                                <div class="fw-semibold text-dark">@Model.PermisosPantalla[i].NombrePantalla</div>
                                                <div class="text-muted" style="font-size: 0.85rem;">@Model.PermisosPantalla[i].Ruta</div>
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check form-check-inline m-0">
                                                    <input asp-for="PermisosPantalla[i].Lectura" class="form-check-input" type="checkbox" />
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check form-check-inline m-0">
                                                    <input asp-for="PermisosPantalla[i].Creacion" class="form-check-input" type="checkbox" />
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check form-check-inline m-0">
                                                    <input asp-for="PermisosPantalla[i].Edicion" class="form-check-input" type="checkbox" />
                                                </div>
                                            </td>
                                            <td class="pe-4 text-center">
                                                <div class="form-check form-check-inline m-0">
                                                    <input asp-for="PermisosPantalla[i].Eliminacion" class="form-check-input" type="checkbox" />
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a href="/seguridad/catalogo-roles" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary border shadow-sm px-4 fw-medium text-primary">
                        <i class="fas fa-save me-1"></i>Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
