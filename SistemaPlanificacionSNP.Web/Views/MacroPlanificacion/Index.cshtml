@model SistemaPlanificacionSNP.Web.Models.MacroPlanificacionIndexViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Macro Planificación";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-globe-americas me-2 text-primary"></i>Macro Planificación</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Gestión de Planes Nacionales de Desarrollo y Objetivos Macro (PND).</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/macroplanificacion/planes/crear" class="btn btn-secondary border shadow-sm px-4 fw-medium">
                <i class="fas fa-plus me-2"></i>Nuevo Plan Nacional
            </a>
        </div>
    </div>

    <!-- Indicadores Superiores -->
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 4px solid #3b82f6;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Total Planes Nacionales</p>
                        <h2 class="mb-0 fw-bolder text-dark">@Model.Resumen.TotalPlanes</h2>
                    </div>
                    <div class="rounded-circle p-3 bg-primary bg-opacity-10 text-primary">
                        <i class="fas fa-book fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 4px solid #10b981;">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted mb-1 text-uppercase tracking-wider text-xs fw-bold">Objetivos Macro Formulados</p>
                        <h2 class="mb-0 fw-bolder text-dark">@Model.Resumen.TotalObjetivos</h2>
                    </div>
                    <div class="rounded-circle p-3 bg-success bg-opacity-10 text-success">
                        <i class="fas fa-bullseye fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-dark"><i class="fas fa-list me-2 text-primary"></i>Directorio de Planes Nacionales</h6>
        </div>

        <div class="card-body p-4 bg-light bg-opacity-50 border-bottom">
            <form method="get" action="/macroplanificacion/planes" class="row g-2 align-items-center">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="buscar" value="@Model.Buscar" class="form-control border-start-0" placeholder="Buscar por nombre del plan..." />
                    </div>
                </div>
                <div class="col-12 col-md-4 col-lg-2">
                    <button type="submit" class="btn btn-secondary w-100">Buscar</button>
                </div>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-white">
                        <tr>
                            <th class="ps-4 border-0 text-xs text-muted fw-bold">ID / NOMBRE DEL PLAN</th>
                            <th class="border-0 text-xs text-muted fw-bold text-center">VIGENCIA</th>
                            <th class="border-0 text-xs text-muted fw-bold text-center">ESTADO</th>
                            <th class="pe-4 border-0 text-xs text-muted fw-bold text-end">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PlanesNacionales.Count == 0)
                        {
                            <tr><td colspan="4" class="text-center py-5 text-muted">No se encontraron Planes Nacionales.</td></tr>
                        }
                        else
                        {
                            @foreach (var plan in Model.PlanesNacionales)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-primary text-xs tracking-wider mb-1">PND-@plan.PlanNacionalId</div>
                                        <div class="fw-semibold text-dark">@plan.Nombre</div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border"><i class="far fa-calendar-alt me-1 text-muted"></i> @plan.PeriodoInicio - @plan.PeriodoFin</span>
                                    </td>
                                    <td class="text-center">
                                        @if (plan.Estado == "Borrador")
                                        {
                                            <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning border border-warning-subtle px-3 py-1">@plan.Estado</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-1">@plan.Estado</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a href="/macroplanificacion/planes/@plan.PlanNacionalId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="fas fa-sitemap me-1"></i>Estructura
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));

            if (swalSuccess) Swal.fire({ title: '¡Éxito!', text: swalSuccess, icon: 'success', confirmButtonText: 'Continuar' });
            if (swalWarning) Swal.fire({ title: 'Atención', text: swalWarning, icon: 'warning', confirmButtonText: 'Entendido' });
        });
    </script>
}