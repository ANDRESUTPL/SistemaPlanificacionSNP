@model SistemaPlanificacionSNP.Web.Models.ListadoAvancesViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Carga de Avances Físicos y Financieros";
    var modelRegistro = new SistemaPlanificacionSNP.Web.Models.RegistroAvanceViewModel();
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-tasks me-2 text-primary"></i>Seguimiento y Ejecución</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Registro de avance físico y devengado financiero de proyectos activos.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/evaluacion/dashboard" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-chart-pie me-2"></i>Ver Dashboard
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 bg-light bg-opacity-50">
            <form method="get" action="/evaluacion/avances" class="row g-2 align-items-center">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="buscar" value="@Model.Buscar" class="form-control border-start-0" placeholder="Buscar por CUP de proyecto..." />
                    </div>
                </div>
                <div class="col-12 col-md-4 col-lg-2">
                    <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
                </div>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-white">
                        <tr>
                            <th class="ps-4 border-0 text-xs text-muted fw-bold">CUP / PROYECTO</th>
                            <th class="border-0 text-xs text-muted fw-bold">ESTADO</th>
                            <th class="border-0 text-xs text-muted fw-bold" style="width: 20%;">AVANCE FÍSICO</th>
                            <th class="border-0 text-xs text-muted fw-bold" style="width: 20%;">AVANCE FINANCIERO</th>
                            <th class="pe-4 border-0 text-xs text-muted fw-bold text-end">ACCIÓN</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Proyectos.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center py-5 text-muted">No se encontraron proyectos para actualizar.</td></tr>
                        }
                        else
                        {
                            @foreach (var proy in Model.Proyectos)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="text-xs fw-bold text-primary tracking-wider mb-1">CUP: @proy.Codigo</div>
                                        <div class="fw-semibold text-dark mb-1">@proy.Nombre</div>
                                        <div class="text-xs text-muted"><i class="fas fa-history me-1"></i> Actualizado: @proy.FechaUltimaActualizacion.ToString("dd/MM/yyyy")</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-2 py-1">@proy.Estado</span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-between text-xs mb-1">
                                            <span>Ejecución Real</span>
                                            <span class="fw-bold">@proy.AvanceFisico%</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-success" style="width: @proy.AvanceFisico%"></div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-between text-xs mb-1">
                                            <span>Devengado</span>
                                            <span class="fw-bold">@proy.AvanceFinanciero%</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-info" style="width: @proy.AvanceFinanciero%"></div>
                                        </div>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                                onclick="openAvanceModal(@proy.ProyectoId, '@proy.Codigo', '@proy.Nombre', '@proy.Estado', @proy.AvanceFisico, @proy.AvanceFinanciero)">
                                            <i class="fas fa-edit me-1"></i>Reportar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Paginador -->
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white border-top">
                <nav>
                    <ul class="pagination justify-content-end mb-0">
                        <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                            <a class="page-link" href="/evaluacion/avances?buscar=@Model.Buscar&page=@(Model.Page - 1)">Anterior</a>
                        </li>
                        <li class="page-item disabled"><span class="page-link">Página @Model.Page de @Model.TotalPages</span></li>
                        <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" href="/evaluacion/avances?buscar=@Model.Buscar&page=@(Model.Page + 1)">Siguiente</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- Modal para Registrar Avance -->
<div class="modal fade" id="avanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold text-dark"><i class="fas fa-sync-alt me-2 text-primary"></i>Registrar Evaluación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/evaluacion/avances/registrar">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ProyectoId" id="modalProyectoId" />

                <div class="modal-body p-4">
                    <div class="mb-4">
                        <div class="text-xs text-primary fw-bold mb-1" id="modalCodigo"></div>
                        <div class="fw-semibold text-dark" id="modalNombre" style="font-size: 0.95rem; line-height: 1.3;"></div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-medium text-sm">Cambiar Estado Operativo</label>
                            <select name="Estado" id="modalEstado" class="form-select" required>
                                <option value="Formulacion">Formulación</option>
                                <option value="Ejecucion">En Ejecución</option>
                                <option value="Pausado">Pausado / Suspendido</option>
                                <option value="Completado">Completado</option>
                                <option value="Cerrado">Cierre Definitivo</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium text-sm">Avance Físico %</label>
                            <div class="input-group">
                                <input type="number" step="0.01" min="0" max="100" name="AvanceFisico" id="modalFisico" class="form-control" required />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium text-sm">Avance Financiero %</label>
                            <div class="input-group">
                                <input type="number" step="0.01" min="0" max="100" name="AvanceFinanciero" id="modalFinanciero" class="form-control" required />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium text-sm">Justificación Técnica / Observaciones</label>
                            <textarea name="Observaciones" class="form-control" rows="3" placeholder="Explique las variaciones del período..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm"><i class="fas fa-save me-1"></i> Guardar Acta</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));

            if (swalSuccess) Swal.fire({ title: '¡Actualizado!', text: swalSuccess, icon: 'success', confirmButtonText: 'Continuar' });
            if (swalWarning) Swal.fire({ title: 'Atención', text: swalWarning, icon: 'warning', confirmButtonText: 'Revisar' });
        });

        function openAvanceModal(id, codigo, nombre, estado, fisico, financiero) {
            document.getElementById('modalProyectoId').value = id;
            document.getElementById('modalCodigo').innerText = `CUP: ${codigo}`;
            document.getElementById('modalNombre').innerText = nombre;

            // Setear selects e inputs
            let selEstado = document.getElementById('modalEstado');
            for(let i = 0; i < selEstado.options.length; i++) {
                if(selEstado.options[i].value === estado) {
                    selEstado.selectedIndex = i;
                    break;
                }
            }

            document.getElementById('modalFisico').value = fisico;
            document.getElementById('modalFinanciero').value = financiero;

            var myModal = new bootstrap.Modal(document.getElementById('avanceModal'));
            myModal.show();
        }
    </script>
}