@model SistemaPlanificacionSNP.Web.Models.EntidadPublicaCreateViewModel

@{
    ViewData["Title"] = "Registrar Entidad Pública";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-landmark me-2 text-primary"></i>Nueva Entidad Pública</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Registro de institución y asignación de nivel gubernamental.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <a href="/parametrizacion/instituciones" class="btn btn-light border shadow-sm px-4 fw-medium text-secondary">
                <i class="fas fa-arrow-left me-2"></i>Volver al listado
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-xl-10 col-xxl-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white pt-4 pb-3 border-bottom px-4 d-flex align-items-center">
                    <div class="rounded-3 p-2 d-flex align-items-center justify-content-center me-3" style="background-color: #eff6ff; color: #3b82f6;">
                        <i class="fas fa-building fs-5"></i>
                    </div>
                    <h5 class="mb-0 fw-bold text-dark">Información Organizacional</h5>
                </div>
                <div class="card-body p-4 p-xl-5">
                    <form method="post" action="/parametrizacion/instituciones/crear-entidad" id="formCreateEntidad">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger border-0 border-start border-4 border-danger shadow-sm rounded-3 mb-4" role="alert">
                                <div class="d-flex">
                                    <i class="fas fa-exclamation-circle mt-1 me-3 fs-5 text-danger"></i>
                                    <div>
                                        <h6 class="fw-bold mb-1 text-danger">Revisa los campos</h6>
                                        <div asp-validation-summary="All" class="text-danger small mb-0 ps-3"></div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="row g-4">
                            <div class="col-12 col-md-8">
                                <label asp-for="Nombre" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Nombre Oficial <span class="text-danger">*</span></label>
                                <input asp-for="Nombre" class="form-control form-control-lg" placeholder="Ej. Ministerio de Salud Pública" autocomplete="off" />
                                <span asp-validation-for="Nombre" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                            </div>

                            <div class="col-12 col-md-4">
                                <label asp-for="Sigla" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Sigla <span class="text-danger">*</span></label>
                                <input asp-for="Sigla" class="form-control form-control-lg bg-light" placeholder="Ej. MSP" style="text-transform: uppercase;" autocomplete="off" />
                                <span asp-validation-for="Sigla" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="Tipo" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Tipo de Institución <span class="text-danger">*</span></label>
                                <select asp-for="Tipo" class="form-select form-select-lg">
                                    <option value="">Seleccione una opción...</option>
                                    <option value="Ministerio">Ministerio</option>
                                    <option value="Secretaría">Secretaría</option>
                                    <option value="GAD Municipal">GAD Municipal</option>
                                    <option value="GAD Provincial">GAD Provincial</option>
                                    <option value="Empresa Pública">Empresa Pública</option>
                                    <option value="Agencia de Regulación">Agencia de Regulación</option>
                                </select>
                                <span asp-validation-for="Tipo" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                            </div>

                            <div class="col-12 col-md-6">
                                <label asp-for="NivelGobierno" class="form-label fw-medium text-dark text-xs text-uppercase tracking-wider">Nivel de Gobierno <span class="text-danger">*</span></label>
                                <select asp-for="NivelGobierno" class="form-select form-select-lg">
                                    <option value="">Seleccione el nivel...</option>
                                    <option value="Gobierno Central">Gobierno Central</option>
                                    <option value="Gobierno Descentralizado (GAD)">Gobierno Descentralizado (GAD)</option>
                                    <option value="Función Judicial">Función Judicial</option>
                                    <option value="Función Legislativa">Función Legislativa</option>
                                    <option value="Función Electoral">Función Electoral</option>
                                </select>
                                <span asp-validation-for="NivelGobierno" class="text-danger text-xs fw-medium mt-1 d-block"></span>
                            </div>
                        </div>

                        <hr class="border-light-subtle my-5">

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/parametrizacion/instituciones" class="btn btn-outline-secondary px-4 rounded-pill">Cancelar</a>
                            <button type="submit" class="btn btn-secondary px-5 rounded-pill shadow-sm" id="btnSubmit">
                                <i class="fas fa-save me-2"></i>Registrar Entidad
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('formCreateEntidad');
            const btnSubmit = document.getElementById('btnSubmit');

            if (form) {
                form.addEventListener('submit', function(e) {
                    if ($(this).valid()) {
                        btnSubmit.disabled = true;
                        btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Registrando...';
                    }
                });
            }
        });
    </script>
}