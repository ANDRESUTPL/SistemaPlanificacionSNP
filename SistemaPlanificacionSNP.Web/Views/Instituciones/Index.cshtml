@model SistemaPlanificacionSNP.Web.Models.InstitucionesIndexViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Entidades y Períodos";
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom">
        <div>
            <h3 class="mb-1 fw-bold text-dark"><i class="fas fa-building me-2 text-primary"></i>Gestión Institucional</h3>
            <p class="text-muted mb-0" style="font-size: 0.95rem;">Administración de entidades públicas y períodos de planificación.</p>
        </div>
        <div class="mt-3 mt-md-0 d-flex gap-2">
            <button type="button" class="btn btn-outline-primary border shadow-sm px-4 fw-medium" data-bs-toggle="modal" data-bs-target="#addPeriodoModal">
                <i class="fas fa-calendar-plus me-2"></i>Nuevo Período
            </button>
            <a href="/parametrizacion/instituciones/crear-entidad" class="btn btn-secondary border shadow-sm px-4 fw-medium">
                <i class="fas fa-plus me-2"></i>Nueva Entidad
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom-0 px-4 pt-4 pb-0">
            <ul class="nav nav-tabs card-header-tabs" id="institucionesTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-medium" id="entidades-tab" data-bs-toggle="tab" data-bs-target="#entidades-pane" type="button" role="tab">
                        <i class="fas fa-landmark me-1"></i> Entidades Públicas
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-medium" id="periodos-tab" data-bs-toggle="tab" data-bs-target="#periodos-pane" type="button" role="tab">
                        <i class="fas fa-clock me-1"></i> Períodos de Planificación
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-0">
            <div class="tab-content" id="myTabContent">

                <div class="tab-pane fade show active" id="entidades-pane" role="tabpanel" tabindex="0">
                    <div class="p-4 border-bottom bg-light bg-opacity-50">
                        <form method="get" action="/parametrizacion/instituciones" class="row g-2 align-items-center">
                            <div class="col-12 col-md-8 col-lg-6">
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                                    <input type="text" name="buscar" value="@Model.Buscar" class="form-control border-start-0" placeholder="Buscar por nombre o sigla de la entidad..." />
                                </div>
                            </div>
                            <div class="col-12 col-md-4 col-lg-2">
                                <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
                            </div>
                        </form>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-white">
                                <tr>
                                    <th class="ps-4 border-0 text-xs text-muted fw-bold">SIGLA / NOMBRE</th>
                                    <th class="border-0 text-xs text-muted fw-bold">TIPO DE ENTIDAD</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">NIVEL GOBIERNO</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">ESTADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Entidades.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center py-5 text-muted">No se encontraron entidades registradas.</td></tr>
                                }
                                else
                                {
                                    @foreach (var ent in Model.Entidades)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-primary text-sm">@ent.Sigla</div>
                                                <div class="fw-medium text-dark">@ent.Nombre</div>
                                            </td>
                                            <td><span class="badge bg-light text-dark border">@ent.Tipo</span></td>
                                            <td class="text-center">@ent.NivelGobierno</td>
                                            <td class="text-center">
                                                @if (ent.Activa)
                                                {
                                                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle">Activa</span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger-subtle">Inactiva</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade" id="periodos-pane" role="tabpanel" tabindex="0">
                    <div class="table-responsive p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light bg-opacity-50">
                                <tr>
                                    <th class="ps-4 border-0 text-xs text-muted fw-bold">CÓDIGO</th>
                                    <th class="border-0 text-xs text-muted fw-bold">NOMBRE</th>
                                    <th class="border-0 text-xs text-muted fw-bold">VIGENCIA</th>
                                    <th class="border-0 text-xs text-muted fw-bold text-center">ESTADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Periodos.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center py-5 text-muted">No se encontraron períodos de planificación.</td></tr>
                                }
                                else
                                {
                                    @foreach (var per in Model.Periodos)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-secondary text-sm">@per.Codigo</td>
                                            <td class="fw-semibold text-dark">@per.Nombre</td>
                                            <td>
                                                <i class="far fa-calendar-alt text-muted me-1"></i> @per.FechaInicio.ToString("dd/MMM/yyyy")
                                                <i class="fas fa-arrow-right text-muted mx-1 text-xs"></i>
                                                <i class="far fa-calendar-check text-muted me-1"></i> @per.FechaFin.ToString("dd/MMM/yyyy")
                                            </td>
                                            <td class="text-center">
                                                @if (per.Activo)
                                                {
                                                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success-subtle">Vigente</span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle">Histórico</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addPeriodoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold text-dark"><i class="fas fa-calendar-plus me-2 text-primary"></i>Nuevo Período</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/parametrizacion/instituciones/crear-periodo">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium text-sm">Código del Período</label>
                        <input type="text" name="Codigo" class="form-control" required placeholder="Ej. PND-2026" style="text-transform: uppercase;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium text-sm">Nombre Descriptivo</label>
                        <input type="text" name="Nombre" class="form-control" required placeholder="Ej. Período Presidencial 2026-2030" />
                    </div>
                    <div class="row g-3 mb-1">
                        <div class="col-6">
                            <label class="form-label fw-medium text-sm">Fecha Inicio</label>
                            <input type="date" name="FechaInicio" class="form-control" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-medium text-sm">Fecha Fin</label>
                            <input type="date" name="FechaFin" class="form-control" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm"><i class="fas fa-save me-1"></i> Guardar Período</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const swalSuccess = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalSuccess));
            const swalWarning = @Html.Raw(JsonSerializer.Serialize((string?)ViewBag.SwalWarning));

            if (swalSuccess) {
                Swal.fire({ title: '¡Éxito!', text: swalSuccess, icon: 'success', confirmButtonText: 'Continuar' });
            } else if (swalWarning) {
                Swal.fire({ title: 'Atención', text: swalWarning, icon: 'warning', confirmButtonText: 'Entendido' });
            }

            // Mantener pestaña activa si se buscó
            if (window.location.search.includes('buscar=')) {
                var triggerEl = document.querySelector('#institucionesTabs button[data-bs-target="#entidades-pane"]');
                var tab = new bootstrap.Tab(triggerEl);
                tab.show();
            }
        });
    </script>
}